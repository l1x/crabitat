---
import Sidebar from "../components/Sidebar.astro";
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — crabitat</title>
  </head>
  <body>
    <Sidebar active={Astro.url.pathname} />
    <main>
      <slot />
    </main>
  </body>
</html>

<style>
  main {
    flex: 1;
    position: relative;
    z-index: 1;
    padding: 32px 40px;
    margin-left: 220px;
  }
</style>
