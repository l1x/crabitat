---
import type { RoleRecord } from '../lib/types';

interface Props {
  roles: RoleRecord[];
}

const { roles } = Astro.props;

function roleColor(role: string): string {
  switch (role) {
    case 'planner':         return 'role--planner';
    case 'rust-developer':  return 'role--developer';
    case 'astro-developer': return 'role--astro';
    case 'developer':       return 'role--developer';
    case 'tester':          return 'role--tester';
    case 'reviewer':        return 'role--reviewer';
    default:                return 'role--default';
  }
}
---

<div class="data-panel">
  <div class="data-panel-header">
    <span class="data-panel-title">Roles</span>
    <span class="content-count">{roles.length}</span>
    <button class="btn btn--primary btn--sm" id="role-add-btn" style="margin-left: auto;">+ Add Role</button>
  </div>
  <div class="data-panel-body">
    {roles.length === 0 ? (
      <div class="empty-state">
        <div class="empty-state-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4-4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M22 21v-2a4 4 0 00-3-3.87"/>
            <path d="M16 3.13a4 4 0 010 7.75"/>
          </svg>
        </div>
        <div class="empty-state-title">No roles</div>
        <p class="empty-state-desc">Roles define the skills and prompt files for agent specializations.</p>
      </div>
    ) : (
      <div class="role-grid">
        {roles.map((role) => (
          <div class="role-card" data-role={JSON.stringify({ role_id: role.role_id, name: role.name, description: role.description, prompt_files: role.prompt_files, skills: role.skills })}>
            <div class="role-card-header">
              <span class={`role-badge ${roleColor(role.name)}`}>{role.name}</span>
              <button class="role-delete-btn" data-role-id={role.role_id} data-role-name={role.name} title="Delete role">&times;</button>
            </div>
            {role.prompt_files.length > 0 && (
              <div class="role-prompt-files">
                {role.prompt_files.map((pf) => (
                  <span class="role-prompt-file-tag">{pf}</span>
                ))}
              </div>
            )}
            {role.description && (
              <p class="role-desc">{role.description}</p>
            )}
            {role.skills.length > 0 && (
              <div class="role-skills">
                {role.skills.map((skill) => (
                  <span class="role-skill-tag">{skill}</span>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>
    )}
  </div>
</div>

<script>
  // Open modal for editing existing role
  document.querySelectorAll('.role-card[data-role]').forEach((card) => {
    card.addEventListener('click', (e) => {
      // Don't open edit if delete button was clicked
      if ((e.target as HTMLElement).closest('.role-delete-btn')) return;
      const roleData = JSON.parse((card as HTMLElement).dataset.role!);
      if (typeof (window as any).openRoleEditModal === 'function') {
        (window as any).openRoleEditModal(roleData);
      }
    });
  });

  // Open modal for creating a new role
  document.getElementById('role-add-btn')?.addEventListener('click', () => {
    if (typeof (window as any).openRoleEditModal === 'function') {
      (window as any).openRoleEditModal(null); // null = create mode
    }
  });

  // Delete role
  document.querySelectorAll('.role-delete-btn').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      e.stopPropagation();
      const el = btn as HTMLElement;
      const roleId = el.dataset.roleId!;
      const roleName = el.dataset.roleName!;

      if (!confirm(`Delete role "${roleName}"? This cannot be undone.`)) return;

      el.textContent = '\u22EF';
      el.setAttribute('disabled', '');

      try {
        const res = await fetch(`/api/roles/${roleId}`, { method: 'DELETE' });
        if (!res.ok) throw new Error(`${res.status}`);
        window.location.reload();
      } catch {
        el.textContent = '\u00D7';
        el.removeAttribute('disabled');
        alert('Failed to delete role');
      }
    });
  });
</script>

<style>
  .role-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }

  .role-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--panel);
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    cursor: pointer;
    text-align: left;
    font: inherit;
    color: inherit;
    width: 100%;
    transition: border-color 0.15s;
  }

  .role-card:hover {
    border-color: var(--accent, #6366f1);
  }

  .role-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .role-badge {
    font-size: 13px;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .role-badge.role--planner   { background: #ede9fe; color: #6d28d9; }
  .role-badge.role--developer { background: #dbeafe; color: #1d4ed8; }
  .role-badge.role--astro     { background: #fce7f3; color: #be185d; }
  .role-badge.role--tester    { background: #dcfce7; color: #16a34a; }
  .role-badge.role--reviewer  { background: #fef3c7; color: #d97706; }
  .role-badge.role--default   { background: var(--neutral-bg); color: var(--muted); }

  .role-delete-btn {
    background: none;
    border: none;
    font-size: 18px;
    line-height: 1;
    color: var(--muted);
    padding: 2px 6px;
    border-radius: 4px;
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
  }

  .role-delete-btn:hover {
    color: var(--bad);
    background: var(--bad-bg);
  }

  .role-prompt-files {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .role-prompt-file-tag {
    font-size: 11px;
    font-family: var(--font-mono, monospace);
    color: var(--muted);
    background: var(--neutral-bg);
    border: 1px solid var(--line-light);
    border-radius: 3px;
    padding: 1px 6px;
  }

  .role-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.4;
  }

  .role-skills {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .role-skill-tag {
    font-size: 11px;
    font-weight: 500;
    padding: 2px 7px;
    border-radius: 3px;
    background: var(--neutral-bg);
    color: var(--ink);
    border: 1px solid var(--line-light);
  }
</style>
