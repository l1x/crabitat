---
import { listPromptFiles } from "../lib/api-client";

interface Props {
  workflowName: string;
}

const { workflowName } = Astro.props;

let promptFiles: string[] = [];
try {
  promptFiles = await listPromptFiles();
} catch (e) {
  console.error("Failed to list prompt files", e);
}
---

<button class="add-flavor-trigger" data-workflow={workflowName}>+ flavor</button>

<dialog class="flavor-dialog" id={`modal-${workflowName}`}>
  <div class="modal-content">
    <div class="modal-header">
      <h2>Add Flavor to {workflowName}</h2>
      <button class="close-x">✕</button>
    </div>
    
    <div class="divider"></div>

    <form class="flavor-form">
      <div id="add-flavor-error" class="modal-error hidden"></div>

      <div class="field">
        <label for="flavor-name">FLAVOR NAME</label>
        <input type="text" name="name" id="flavor-name" placeholder="e.g. rust, astro, github" required />
      </div>

      <div class="field">
        <label>PROMPT FILES</label>
        <div class="prompt-picker">
          {promptFiles.map((file) => (
            <label class="prompt-item">
              <input type="checkbox" name="prompts" value={file} />
              <span class="file-path">{file}</span>
            </label>
          ))}
          {promptFiles.length === 0 && <p class="empty-prompts">No .md files found in prompts root.</p>}
        </div>
      </div>

      <div class="field preview-field hidden">
        <label>PREVIEW ASSEMBLED PROMPT</label>
        <div class="preview-box">
          <div class="preview-text markdown-body"></div>
        </div>
      </div>

      <div class="actions">
        <button type="button" class="preview-btn">Preview</button>
        <div class="spacer"></div>
        <button type="button" class="cancel-btn">Cancel</button>
        <button type="submit" class="submit-btn">Create Flavor</button>
      </div>
    </form>
  </div>
</dialog>

<script is:inline define:vars={{ workflowName }}>
  const dialog = document.getElementById(`modal-${workflowName}`);
  const form = dialog.querySelector('.flavor-form');
  const closeX = dialog.querySelector('.close-x');
  const cancelBtn = dialog.querySelector('.cancel-btn');
  const previewBtn = dialog.querySelector('.preview-btn');
  const previewField = dialog.querySelector('.preview-field');
  const previewText = dialog.querySelector('.preview-text');
  const errorEl = dialog.querySelector('#add-flavor-error');
  const trigger = document.querySelector(`.add-flavor-trigger[data-workflow="${workflowName}"]`);

  trigger.addEventListener('click', () => dialog.showModal());
  
  const close = () => {
    dialog.close();
    form.reset();
    previewField.classList.add('hidden');
    previewText.innerHTML = '';
    errorEl.classList.add('hidden');
    errorEl.textContent = '';
  };

  closeX?.addEventListener('click', close);
  cancelBtn?.addEventListener('click', close);
  dialog.addEventListener('click', (e) => {
    if (e.target === dialog) close();
  });

  previewBtn.addEventListener('click', async () => {
    const formData = new FormData(form);
    const prompt_paths = formData.getAll('prompts');
    
    if (prompt_paths.length === 0) {
      alert("Select at least one prompt file to preview.");
      return;
    }

    previewBtn.disabled = true;
    previewBtn.textContent = 'Loading...';

    try {
      const res = await fetch(`http://localhost:3001/v1/prompts/content`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ paths: prompt_paths })
      });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      
      previewField.classList.remove('hidden');
      if (typeof window.marked !== 'undefined') {
        previewText.innerHTML = window.marked.parse(data.content || "Empty fragments.");
      } else {
        previewText.textContent = data.content || "Empty fragments.";
      }
    } catch (e) {
      alert(`Error loading preview: ${e.message}`);
    } finally {
      previewBtn.disabled = false;
      previewBtn.textContent = 'Preview';
    }
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const name = formData.get('name');
    const prompt_paths = formData.getAll('prompts');

    if (!name) return;

    const submitBtn = form.querySelector('.submit-btn');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Creating...';
    errorEl.classList.add('hidden');

    try {
      const res = await fetch(`http://localhost:3001/v1/workflows/${workflowName}/flavors`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, prompt_paths })
      });

      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.error || 'Failed to create flavor');
      }

      window.location.reload();
    } catch (err) {
      errorEl.textContent = err.message;
      errorEl.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Create Flavor';
    }
  });
</script>

<style>
  .add-flavor-trigger {
    border: 1px dashed var(--btn-border);
    color: var(--muted);
    border-radius: 14px;
    padding: 4px 14px;
    font-size: 13px;
    font-weight: 500;
    transition: all 0.2s;
    cursor: pointer;
  }

  .add-flavor-trigger:hover {
    border-color: var(--muted);
    color: var(--heading);
    background: rgba(255, 255, 255, 0.03);
  }

  .flavor-dialog {
    background: transparent;
    border: none;
    padding: 0;
    max-width: 100vw;
    max-height: 100vh;
    margin: auto;
  }

  .flavor-dialog::backdrop {
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(4px);
  }

  .modal-content {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 32px;
    width: 500px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  h2 {
    color: var(--heading);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .close-x {
    color: var(--faint);
    font-size: 18px;
    padding: 4px;
    cursor: pointer;
    background: transparent;
    border: none;
  }

  .close-x:hover {
    color: var(--heading);
  }

  .divider {
    height: 1px;
    background: var(--border-subtle);
    margin-bottom: 24px;
  }

  .modal-error {
    background: rgba(238, 85, 85, 0.1);
    color: #f85149;
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 13px;
    margin-bottom: 24px;
    border: 1px solid rgba(238, 85, 85, 0.2);
  }

  .field {
    margin-bottom: 24px;
  }

  label {
    display: block;
    color: var(--muted);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 10px;
  }

  input[type="text"] {
    width: 100%;
    padding: 12px 16px;
    background: var(--input-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--body);
    font-size: 15px;
    outline: none;
    transition: border-color 0.2s;
  }

  input[type="text"]:focus {
    border-color: var(--muted);
  }

  .prompt-picker {
    background: var(--input-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    max-height: 240px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }

  .prompt-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    cursor: pointer;
    border-bottom: 1px solid var(--border-subtle);
  }

  .prompt-item:hover {
    background: rgba(255, 255, 255, 0.03);
  }

  .preview-box {
    background: #0a0a0a;
    border: 1px solid var(--border);
    border-radius: 8px;
    max-height: 200px;
    overflow-y: auto;
    padding: 16px;
  }

  .preview-text {
    font-family: monospace;
    font-size: 13px;
    color: var(--body);
    white-space: pre-wrap;
    line-height: 1.5;
  }

  .actions {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 12px;
    margin-top: 32px;
  }

  .spacer {
    flex: 1;
  }

  .cancel-btn, .submit-btn, .preview-btn {
    padding: 10px 24px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    transition: all 0.2s;
    cursor: pointer;
  }

  .preview-btn {
    color: var(--muted);
    background: transparent;
    border: 1px solid var(--border);
  }

  .preview-btn:hover {
    color: var(--heading);
    border-color: var(--muted);
  }

  .cancel-btn {
    color: var(--muted);
    background: transparent;
    border: none;
  }

  .cancel-btn:hover {
    color: var(--heading);
    background: rgba(255, 255, 255, 0.05);
  }

  .submit-btn {
    background: #d0d0d0;
    color: #000;
    border: 1px solid #d0d0d0;
  }

  .submit-btn:hover {
    background: #ffffff;
    border-color: #ffffff;
  }

  .submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .hidden {
    display: none !important;
  }
</style>
