---
import type { RepoRecord, MissionRecord } from '../lib/types';
import AddRepoModal from './AddRepoModal.astro';

interface Props {
  repos: RepoRecord[];
  missions?: MissionRecord[];
  repoIssueCounts?: Record<string, number>;
}

const { repos, missions = [], repoIssueCounts = {} } = Astro.props;

function issueCount(repoId: string): number {
  return repoIssueCounts[repoId] ?? 0;
}

function missionCount(repoId: string): number {
  return missions.filter((m) => m.repo_id === repoId).length;
}
---

<div class="repo-list-header">
  <button class="btn btn--primary btn--sm" id="repo-list-add-btn">+ Add Repo</button>
</div>

<AddRepoModal />

{repos.length === 0 ? (
  <div class="data-panel">
    <div class="data-panel-body">
      <div class="empty-state">
        <div class="empty-state-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
        </div>
        <div class="empty-state-title">No repos onboarded</div>
        <p class="empty-state-desc">Add a GitHub repository to get started.</p>
      </div>
    </div>
  </div>
) : (
  <div class="card-grid">
    {repos.map((repo) => (
      <a href={`/repos/${repo.owner}/${repo.name}`} class="card repo-card-link" data-repo-id={repo.repo_id}>
        <div class="card-title">
          <span>{repo.full_name}</span>
          <button class="repo-delete-btn" data-repo-id={repo.repo_id} data-repo-name={repo.full_name} title="Remove repo">&times;</button>
        </div>
        <div class="card-meta">
          <code>{repo.default_branch}</code>
          {repo.language && <span>&middot; {repo.language}</span>}
        </div>
        <div class="repo-card-stats">
          <span class="repo-card-stat">{issueCount(repo.repo_id)} issues</span>
          <span class="repo-card-stat">{missionCount(repo.repo_id)} missions</span>
        </div>
      </a>
    ))}
  </div>
)}

<script>
  const addBtn = document.getElementById('repo-list-add-btn')!;
  addBtn.addEventListener('click', () => {
    if (typeof (window as any).openAddRepoModal === 'function') {
      (window as any).openAddRepoModal();
    }
  });

  document.querySelectorAll('.repo-delete-btn').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      e.stopPropagation();
      const el = btn as HTMLElement;
      const repoId = el.dataset.repoId!;
      const repoName = el.dataset.repoName!;

      if (!confirm(`Remove ${repoName}? This only removes it from Crabitat, not from GitHub.`)) return;

      el.textContent = '\u22EF';
      el.setAttribute('disabled', '');

      try {
        const res = await fetch(`/api/repos/${repoId}`, { method: 'DELETE' });
        if (!res.ok) throw new Error(`${res.status}`);
        window.location.reload();
      } catch {
        el.textContent = '\u00D7';
        el.removeAttribute('disabled');
        alert('Failed to remove repo');
      }
    });
  });
</script>

<style>
  .repo-delete-btn {
    background: none;
    border: none;
    font-size: 18px;
    line-height: 1;
    color: var(--muted);
    padding: 2px 6px;
    border-radius: 4px;
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
  }

  .repo-delete-btn:hover {
    color: var(--bad);
    background: var(--bad-bg);
  }
</style>
