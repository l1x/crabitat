---
interface Props {
  active: string;
}

const { active } = Astro.props;

const links = [
  { href: "/repos", label: "Repositories" },
  { href: "/issues", label: "Issues" },
  { href: "/workflows", label: "Workflows" },
  { href: "/missions", label: "Missions" },
];
---

<nav>
  <div class="logo">crabitat</div>
  <div class="divider"></div>
  <ul>
    {links.map((link) => {
      const isActive = active.startsWith(link.href);
      return (
        <li>
          <a href={link.href} class:list={[{ active: isActive }]}>
            {isActive && <span class="dot" />}
            {link.label}
          </a>
        </li>
      );
    })}
  </ul>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 220px;
    height: 100vh;
    background: var(--bg-sidebar);
    border-right: 1px solid var(--border-subtle);
    z-index: 10;
    padding: 20px 12px;
  }

  .logo {
    color: var(--heading);
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.3px;
    padding: 0 16px;
  }

  .divider {
    height: 1px;
    background: var(--border-subtle);
    margin: 16px 16px 12px;
  }

  ul {
    list-style: none;
  }

  a {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px;
    border-radius: 6px;
    color: var(--muted);
    font-size: 13px;
    transition: background 0.15s;
  }

  a:hover {
    background: rgba(255, 255, 255, 0.03);
  }

  a.active {
    background: #1a1a1a;
    color: var(--heading);
    font-weight: 500;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }
</style>
