---
import { getSystemStatus } from "../lib/api-client";
import type { SystemStatus } from "../lib/types";
import SchemeToggle from "./SchemeToggle.astro";
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  active: string;
}

const { active } = Astro.props;

let status: SystemStatus | null = null;
try {
  status = await getSystemStatus();
} catch (e) {
  console.error("Failed to fetch system status", e);
}

const links = [
  { href: "/repos", label: "Repositories" },
  { href: "/issues", label: "Issues" },
  { href: "/workflows", label: "Workflows" },
  { href: "/missions", label: "Missions" },
  { href: "/settings", label: "Settings" },
];
---

<nav>
  <div class="logo-row">
    <div class="logo">crabitat</div>
    <div class="toggles">
      <SchemeToggle />
      <ThemeToggle />
    </div>
  </div>
  <div class="divider"></div>
  <ul>
    {links.map((link) => {
      const isActive = active.startsWith(link.href);
      return (
        <li>
          <a href={link.href} class:list={[{ active: isActive }]}>
            {isActive && <span class="dot" />}
            {link.label}
          </a>
        </li>
      );
    })}
  </ul>

  <div class="status-box">
    <div class="status-header">SYSTEM STATUS</div>
    <div class="status-item">
      <span class:list={["indicator", status?.gh_installed ? "online" : "offline"]}></span>
      <span class="label">GitHub CLI</span>
      <span class="value">{status?.gh_installed ? "Installed" : "Missing"}</span>
    </div>
    <div class="status-item">
      <span class:list={["indicator", status?.gh_auth_status ? "online" : "offline"]}></span>
      <span class="label">GitHub Auth</span>
      <span class="value">{status?.gh_auth_status ? "Online" : "Offline"}</span>
    </div>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 220px;
    height: 100vh;
    background: var(--bg-sidebar);
    border-right: 1px solid var(--border-subtle);
    z-index: 10;
    padding: 20px 12px;
    display: flex;
    flex-direction: column;
  }

  .logo-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 16px;
  }

  .toggles {
    display: flex;
    gap: 2px;
  }

  .logo {
    color: var(--heading);
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.5px;
  }

  .divider {
    height: 1px;
    background: var(--border-subtle);
    margin: 20px 16px 16px;
  }

  ul {
    list-style: none;
    flex-grow: 1;
  }

  a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: 8px;
    color: var(--muted);
    font-size: 16px;
    font-weight: 500;
    transition: background 0.15s;
  }

  a:hover {
    background: var(--overlay-light);
  }

  a.active {
    background: var(--sidebar-active-bg);
    color: var(--heading);
    font-weight: 500;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }

  .status-box {
    margin-top: auto;
    background: var(--overlay-subtle);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    padding: 14px;
    font-size: 12px;
  }

  .status-header {
    color: var(--muted);
    font-weight: 600;
    margin-bottom: 10px;
    letter-spacing: 0.5px;
  }

  .status-item {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
  }

  .indicator {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .online { background: var(--status-success); box-shadow: 0 0 4px var(--status-success); }
  .offline { background: var(--status-error); box-shadow: 0 0 4px var(--status-error); }

  .label { color: var(--muted); flex-grow: 1; }
  .value { color: var(--body); font-family: monospace; }
</style>
