---
import type { Repo } from "../lib/types";

interface Props {
  repo: Repo;
}

const { repo } = Astro.props;
---

<div class="card">
  <div class="header">
    <span class="dot"></span>
    <span class="name">{repo.owner} / {repo.name}</span>
  </div>

  <div class="field">
    <div class="label">LOCAL PATH</div>
    <div class="value path-container" title={repo.local_path}>
      <span class="path-content" data-full-path={repo.local_path}>{repo.local_path}</span>
    </div>
  </div>

  <div class="footer">
    <a href={`/issues/${repo.repo_id}`} class="issues-btn">View Issues</a>
    <form method="POST" action={`/api/repos/${repo.repo_id}/delete`} onsubmit="return confirm('Are you sure you want to delete this repository? This will remove all cached issues and missions.');">
      <button type="submit" class="delete-btn">Delete</button>
    </form>
  </div>
</div>

<style>
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    min-width: 0; /* Allow card to shrink if needed */
  }

  .header {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    box-shadow: 0 0 8px rgba(212, 160, 84, 0.4);
  }

  .name {
    color: var(--heading);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  .label {
    color: var(--muted);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .value {
    color: var(--body);
    font-size: 15px;
    background: rgba(255, 255, 255, 0.02);
    border-radius: 6px;
    border: 1px solid var(--border-subtle);
    min-width: 0;
    height: 36px;
    display: flex;
    align-items: center;
    padding: 0 12px;
  }

  .path-container {
    font-family: monospace;
    width: 100%;
    overflow: hidden;
    white-space: nowrap;
  }

  .path-content {
    display: block;
    direction: rtl;
    text-align: left;
    text-overflow: ellipsis;
    overflow: hidden;
    white-space: nowrap;
    /* This combo ensures the ellipsis is on the left and the end of the string is on the right */
  }

  .footer {
    border-top: 1px solid var(--border-subtle);
    padding-top: 20px;
    margin-top: 8px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .issues-btn {
    font-size: 14px;
    font-weight: 600;
    color: var(--heading);
    padding: 8px 20px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--btn-border);
    border-radius: 6px;
    transition: all 0.2s;
  }

  .issues-btn:hover {
    border-color: var(--accent);
    background: rgba(212, 160, 84, 0.1);
  }

  .delete-btn {
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
    padding: 6px 14px;
    transition: color 0.2s;
    background: transparent;
    border: none;
    cursor: pointer;
  }

  .delete-btn:hover {
    color: #f85149;
  }
</style>
