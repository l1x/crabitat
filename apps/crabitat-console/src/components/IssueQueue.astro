---
import type { RepoRecord } from '../lib/types';
import EmptyState from './EmptyState.astro';

interface Props {
  repos: RepoRecord[];
}

const { repos } = Astro.props;
---

<div class="data-panel">
  <div class="data-panel-header">
    <span class="data-panel-title">Issue Queue</span>
  </div>
  <div class="data-panel-body">
    {repos.length === 0 ? (
      <EmptyState
        title="No repos registered"
        description="Add a repo to start queuing issues."
      />
    ) : (
      <div id="queue-panel">
        <div style="margin-bottom:16px">
          <label for="queue-repo-select" style="font-weight:500;margin-right:8px">Repository:</label>
          <select id="queue-repo-select" class="input" style="display:inline-block;width:auto">
            {repos.map((r) => (
              <option value={r.repo_id}>{r.full_name}</option>
            ))}
          </select>
          <button class="btn btn--primary" id="queue-refresh-btn" style="margin-left:8px">Refresh</button>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
          <!-- Left: GitHub Issues -->
          <div class="data-panel">
            <div class="data-panel-header">
              <span class="data-panel-title">Open Issues</span>
            </div>
            <div class="data-panel-body" id="issues-list">
              <div class="empty-state">
                <div class="empty-state-title">Select a repo and click Refresh</div>
              </div>
            </div>
          </div>

          <!-- Right: Execution Queue -->
          <div class="data-panel">
            <div class="data-panel-header">
              <span class="data-panel-title">Execution Queue</span>
            </div>
            <div class="data-panel-body" id="queue-list">
              <div class="empty-state">
                <div class="empty-state-title">No missions queued</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    )}
  </div>
</div>
