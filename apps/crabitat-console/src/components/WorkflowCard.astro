---
import type { WorkflowSummary, WorkflowDetail } from "../lib/types";

interface Props {
  summary: WorkflowSummary;
  detail: WorkflowDetail;
}

const { summary, detail } = Astro.props;
---

<div class="card">
  <div class="header">
    <span class="wf-name">{summary.name}</span>
    <span class="repo-label">{summary.repo_owner}/{summary.repo_name}</span>
  </div>

  {summary.description && (
    <p class="description">{summary.description}</p>
  )}

  <div class="section">
    <div class="section-label">FLAVORS</div>
    <div class="flavors">
      {detail.flavors.map((f) => (
        <span class="pill">{f.name}</span>
      ))}
      <form
        method="POST"
        action={`/api/workflows/${summary.workflow_id}/flavors/create`}
        class="flavor-form"
      >
        <input
          type="text"
          name="name"
          placeholder="name"
          required
          class="flavor-input"
        />
        <button type="submit" class="add-flavor-btn">+ flavor</button>
      </form>
    </div>
  </div>

  <div class="section">
    <div class="section-label">STEPS</div>
    <div class="steps">
      {detail.steps.map((step, i) => (
        <div class="step-row">
          <div class="step-connector">
            <svg width="24" height="24" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10" fill="none" stroke="#333" stroke-width="1" />
              <text x="12" y="16" text-anchor="middle" fill="#888" font-size="11">{i + 1}</text>
            </svg>
            {i < detail.steps.length - 1 && <div class="dash-line" />}
          </div>
          <div class="step-info">
            <span class="step-name">{step.name}</span>
            <span class="step-prompt">{step.prompt_template}</span>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="footer">
    <form method="POST" action={`/api/workflows/${summary.workflow_id}/delete`}>
      <button type="submit" class="delete-btn">Delete</button>
    </form>
  </div>
</div>

<style>
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .wf-name {
    color: #ece5d8;
    font-size: 16px;
    font-weight: 600;
  }

  .repo-label {
    color: #555;
    font-size: 11px;
  }

  .description {
    color: #777;
    font-size: 12px;
    margin: 0;
  }

  .section {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .section-label {
    color: var(--muted);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.8px;
  }

  .flavors {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
  }

  .pill {
    border: 1px solid #333;
    color: #aaa;
    border-radius: 11px;
    padding: 2px 10px;
    font-size: 11px;
  }

  .flavor-form {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .flavor-input {
    width: 80px;
    padding: 2px 8px;
    background: transparent;
    border: 1px dashed #333;
    border-radius: 4px;
    color: var(--body);
    font-size: 11px;
    font-family: inherit;
    outline: none;
  }

  .flavor-input:focus {
    border-color: var(--accent);
  }

  .flavor-input::placeholder {
    color: var(--muted);
  }

  .add-flavor-btn {
    color: #555;
    font-size: 11px;
    border: 1px dashed #333;
    border-radius: 11px;
    padding: 2px 10px;
    transition: color 0.15s;
  }

  .add-flavor-btn:hover {
    color: #aaa;
  }

  .steps {
    display: flex;
    flex-direction: column;
  }

  .step-row {
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .step-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }

  .dash-line {
    width: 1px;
    height: 16px;
    border-left: 1px dashed #333;
  }

  .step-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-top: 3px;
  }

  .step-name {
    color: #666;
    font-size: 12px;
    font-weight: 500;
  }

  .step-prompt {
    color: var(--muted);
    font-size: 11px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 300px;
  }

  .footer {
    border-top: 1px solid var(--border-subtle);
    padding-top: 12px;
    margin-top: 4px;
    display: flex;
    justify-content: flex-end;
  }

  .delete-btn {
    font-size: 11px;
    color: var(--muted);
    padding: 4px 12px;
    border: 1px solid var(--border);
    border-radius: 4px;
    transition: all 0.15s;
  }

  .delete-btn:hover {
    color: #e55;
    border-color: #e55;
  }
</style>
