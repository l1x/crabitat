---
import type { WorkflowSummary, WorkflowDetail } from "../lib/types";
import AddFlavorModal from "./AddFlavorModal.astro";
import FlavorDetailModal from "./FlavorDetailModal.astro";

interface Props {
  summary: WorkflowSummary;
  detail: WorkflowDetail;
}

const { summary, detail } = Astro.props;
---

<div class="card" data-workflow-name={summary.name}>
  <div class="header">
    <span class="wf-name">{summary.name}</span>
    {detail.version && <span class="version">v{detail.version}</span>}
  </div>

  {summary.description && (
    <p class="description">{summary.description}</p>
  )}

  <div class="section">
    <div class="section-label">FLAVORS</div>
    <div class="flavors">
      {detail.flavors.map((f) => (
        <FlavorDetailModal flavor={f} />
      ))}
      <AddFlavorModal workflowName={summary.name} />
    </div>
  </div>

  <div class="section">
    <div class="section-label">STEPS</div>
    <div class="steps">
      {detail.steps.map((step, i) => (
        <div class="step-row">
          <div class="step-connector">
            <svg width="28" height="28" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="11" fill="none" stroke="currentColor" class="step-circle" stroke-width="1.2" />
              <text x="12" y="16.5" text-anchor="middle" fill="currentColor" class="step-number" font-size="13" font-weight="600">{i + 1}</text>
            </svg>
            {i < detail.steps.length - 1 && <div class="dash-line" />}
          </div>
          <div class="step-info">
            <span class="step-name">{step.id}</span>
            <span class="step-prompt">{step.prompt_file}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .wf-name {
    color: var(--heading);
    font-size: 20px;
    font-weight: 700;
  }

  .version {
    color: var(--faint);
    font-size: 13px;
    font-family: monospace;
  }

  .description {
    color: var(--muted);
    font-size: 15px;
    margin: 0;
    line-height: 1.5;
  }

  .section {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .section-label {
    color: var(--muted);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .flavors {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 20px;
  }

  .steps {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .step-row {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }

  .step-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }

  .dash-line {
    width: 1px;
    height: 20px;
    border-left: 1px dashed var(--btn-border);
  }

  .step-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: 4px;
  }

  .step-name {
    color: var(--body);
    font-size: 15px;
    font-weight: 600;
  }

  .step-prompt {
    color: var(--muted);
    font-size: 13px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 400px;
    font-family: monospace;
  }
</style>
