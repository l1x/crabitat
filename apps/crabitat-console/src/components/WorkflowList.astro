---
import type { WorkflowRecord, WorkflowStepRecord } from '../lib/types';

interface Props {
  workflows: WorkflowRecord[];
}

const { workflows } = Astro.props;

const STEP_COLORS = ['step--1', 'step--2', 'step--3', 'step--4', 'step--5'];

function stepColor(index: number): string {
  return STEP_COLORS[index % STEP_COLORS.length];
}

function stepNumber(step: WorkflowStepRecord): string {
  return String(step.position + 1);
}

function includeName(path: string): string {
  return path.replace(/\.md$/, '').split('/').pop() || path;
}
---

<div class="data-panel">
  <div class="data-panel-header">
    <span class="data-panel-title">Workflows</span>
    <span class="content-count">{workflows.length}</span>
  </div>
  <div class="data-panel-body">
    {workflows.length === 0 ? (
      <div class="empty-state">
        <div class="empty-state-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/>
            <path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/>
          </svg>
        </div>
        <div class="empty-state-title">No workflows</div>
        <p class="empty-state-desc">Workflows define step-by-step pipelines that missions follow.</p>
      </div>
    ) : (
      <div class="wf-list">
        {workflows.map((wf) => (
          <div class="wf-card">
            <div class="wf-card-top">
              <div class="wf-card-identity">
                <h3 class="wf-name">{wf.name}</h3>
                <div class="wf-badges">
                  {wf.include.length > 0 ? (
                    wf.include.map((s) => (
                      <button class="domain-tag domain-tag--clickable wf-prompt-link" data-path={s}>{includeName(s)}</button>
                    ))
                  ) : (
                    <span class="domain-tag domain-tag--any">any</span>
                  )}
                  <span class="wf-version">v{wf.version}</span>
                  <span class={`source-tag source-tag--${wf.source}`}>
                    {wf.source === 'toml' ? 'TOML' : 'Manual'}
                  </span>
                  {wf.commit_hash && (
                    <span class="wf-commit" title={wf.commit_hash}>
                      {wf.commit_hash.slice(0, 8)}
                    </span>
                  )}
                </div>
              </div>
              {wf.description && (
                <p class="wf-desc">{wf.description}</p>
              )}
            </div>

            <div class="wf-pipeline">
              {wf.steps.map((step, i) => (
                <>
                  <div class={`wf-step ${step.condition ? 'wf-step--conditional' : ''}`}>
                    <div class={`wf-step-num ${stepColor(i)}`}>
                      {stepNumber(step)}
                    </div>
                    <div class="wf-step-body">
                      <div class="wf-step-header">
                        <span class="wf-step-id">{step.step_id}</span>
                      </div>
                      {step.prompt_file && (
                        <button class="wf-step-prompt wf-prompt-link" data-path={step.prompt_file}>
                          <svg viewBox="0 0 16 16" width="11" height="11" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M10 1H4a1.5 1.5 0 00-1.5 1.5v11A1.5 1.5 0 004 15h8a1.5 1.5 0 001.5-1.5V5z"/>
                            <polyline points="10 1 10 5 13 5"/>
                          </svg>
                          {step.prompt_file.split('/').pop()}
                        </button>
                      )}
                      {step.depends_on.length > 0 && (
                        <div class="wf-step-deps">
                          <svg class="wf-dep-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M2 8h12M10 4l4 4-4 4"/>
                          </svg>
                          after {step.depends_on.join(', ')}
                        </div>
                      )}
                      {step.condition && (
                        <div class="wf-step-cond">
                          <svg class="wf-cond-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M8 2L14 8L8 14L2 8Z"/>
                          </svg>
                          {step.condition}
                        </div>
                      )}
                      {step.max_retries > 0 && (
                        <div class="wf-step-retry">
                          <svg class="wf-retry-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M2 8a6 6 0 0111.5-2.3M14 2v4h-4"/>
                            <path d="M14 8a6 6 0 01-11.5 2.3M2 14v-4h4"/>
                          </svg>
                          {step.max_retries} retries
                        </div>
                      )}
                      {step.include.length > 0 && JSON.stringify(step.include) !== JSON.stringify(wf.include) && (
                        <div class="wf-step-include">
                          {step.include.map((s) => (
                            <button class="domain-tag domain-tag--clickable wf-prompt-link" data-path={s}>{includeName(s)}</button>
                          ))}
                        </div>
                      )}
                    </div>
                  </div>
                  {i < wf.steps.length - 1 && (
                    <div class="wf-connector">
                      <div class="wf-connector-line" />
                    </div>
                  )}
                </>
              ))}
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</div>

<!-- Prompt preview modal -->
<dialog class="modal modal--wide" id="prompt-preview-modal">
  <div class="modal-content">
    <div class="modal-header">
      <span class="modal-title" id="prompt-modal-title">Prompt Preview</span>
      <button class="modal-close" id="prompt-modal-close">&times;</button>
    </div>
    <div class="modal-body">
      <pre class="prompt-preview-content" id="prompt-modal-content">Loading...</pre>
    </div>
  </div>
</dialog>

<script>
  function escapeHtml(text: string): string {
    return text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  const modal = document.getElementById('prompt-preview-modal') as HTMLDialogElement;
  const modalTitle = document.getElementById('prompt-modal-title')!;
  const modalContent = document.getElementById('prompt-modal-content')!;
  const modalClose = document.getElementById('prompt-modal-close')!;

  modalClose.addEventListener('click', () => modal.close());
  modal.addEventListener('click', (e) => {
    if (e.target === modal) modal.close();
  });

  document.querySelectorAll('.wf-prompt-link').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      const path = (btn as HTMLElement).dataset.path;
      if (!path) return;

      modalTitle.textContent = path;
      modalContent.textContent = 'Loading\u2026';
      modal.showModal();

      try {
        const res = await fetch(`/api/prompt-files/preview?path=${encodeURIComponent(path)}`);
        if (!res.ok) throw new Error(`${res.status}`);
        const data = await res.json();
        modalContent.innerHTML = escapeHtml(data.content);
      } catch {
        modalContent.textContent = 'Failed to load prompt file.';
      }
    });
  });
</script>

<style>
  .wf-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .wf-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--panel);
    overflow: hidden;
  }

  .wf-card-top {
    padding: 16px 20px 12px;
    border-bottom: 1px solid var(--line-light);
  }

  .wf-card-identity {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }

  .wf-name {
    font-size: 15px;
    font-weight: 600;
    color: var(--ink);
  }

  .wf-badges {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .wf-version {
    font-size: 11px;
    font-weight: 600;
    color: var(--muted);
    background: var(--neutral-bg);
    padding: 2px 8px;
    border-radius: 4px;
    letter-spacing: 0.02em;
  }

  .source-tag {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 2px 6px;
    border-radius: 3px;
  }

  .source-tag--toml {
    background: #dbeafe;
    color: #1d4ed8;
  }

  .source-tag--manual {
    background: #f3e8ff;
    color: #7c3aed;
  }

  .wf-commit {
    font-size: 11px;
    font-family: var(--font-mono, monospace);
    color: var(--muted);
    background: var(--neutral-bg);
    padding: 2px 6px;
    border-radius: 3px;
    cursor: default;
  }

  .wf-desc {
    font-size: 13px;
    color: var(--muted);
    margin-top: 6px;
    line-height: 1.4;
  }

  /* Pipeline */
  .wf-pipeline {
    padding: 16px 20px 20px;
    display: flex;
    align-items: flex-start;
    gap: 0;
    overflow-x: auto;
  }

  .wf-step {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 14px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: #fff;
    min-width: 130px;
    flex-shrink: 0;
  }

  .wf-step--conditional {
    border-style: dashed;
    background: #fefce8;
  }

  .wf-step-num {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .wf-step-num.step--1 { background: #ede9fe; color: #6d28d9; }
  .wf-step-num.step--2 { background: #dbeafe; color: #1d4ed8; }
  .wf-step-num.step--3 { background: #dcfce7; color: #16a34a; }
  .wf-step-num.step--4 { background: #fef3c7; color: #d97706; }
  .wf-step-num.step--5 { background: var(--neutral-bg); color: var(--muted); }

  .wf-step-body {
    min-width: 0;
  }

  .wf-step-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 2px;
  }

  .wf-step-id {
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
  }

  .wf-step-prompt {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    color: var(--primary, #2563eb);
    background: none;
    border: none;
    padding: 0;
    margin-top: 3px;
    cursor: pointer;
    font-family: inherit;
  }

  .wf-step-prompt:hover {
    text-decoration: underline;
  }

  .wf-step-prompt svg {
    opacity: 0.6;
  }

  .wf-step-deps,
  .wf-step-cond,
  .wf-step-retry {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    margin-top: 3px;
  }

  .wf-step-deps {
    color: var(--muted);
  }

  .wf-step-cond {
    color: #b45309;
    font-style: italic;
  }

  .wf-step-retry {
    color: var(--muted);
  }

  .wf-step-include {
    display: flex;
    flex-wrap: wrap;
    gap: 3px;
    margin-top: 4px;
  }

  .domain-tag--clickable {
    cursor: pointer;
    border: none;
    font: inherit;
  }

  .domain-tag--clickable:hover {
    opacity: 0.8;
    text-decoration: underline;
  }

  .wf-dep-icon,
  .wf-cond-icon,
  .wf-retry-icon {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
  }

  /* Connector */
  .wf-connector {
    display: flex;
    align-items: center;
    padding: 0;
    flex-shrink: 0;
    align-self: center;
  }

  .wf-connector-line {
    width: 20px;
    height: 2px;
    background: var(--line);
    position: relative;
  }

  .wf-connector-line::after {
    content: '';
    position: absolute;
    right: 0;
    top: -3px;
    border: 4px solid transparent;
    border-left: 5px solid var(--line);
  }

  /* Modal */
  .modal {
    border: none;
    border-radius: var(--radius-lg, 12px);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    padding: 0;
    max-width: 800px;
    width: 90vw;
    max-height: 80vh;
  }

  .modal::backdrop {
    background: rgba(0, 0, 0, 0.4);
  }

  .modal-content {
    display: flex;
    flex-direction: column;
    max-height: 80vh;
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid var(--line, #e5e7eb);
  }

  .modal-title {
    font-size: 14px;
    font-weight: 600;
    font-family: var(--font-mono, monospace);
    color: var(--ink, #111);
  }

  .modal-close {
    background: none;
    border: none;
    font-size: 20px;
    cursor: pointer;
    color: var(--muted, #6b7280);
    padding: 0 4px;
    line-height: 1;
  }

  .modal-close:hover {
    color: var(--ink, #111);
  }

  .modal-body {
    padding: 16px 20px;
    overflow-y: auto;
    flex: 1;
  }

  .modal-body .prompt-preview-content {
    font-size: 12px;
    line-height: 1.6;
    color: var(--ink, #111);
    white-space: pre-wrap;
    word-break: break-word;
    margin: 0;
    font-family: var(--font-mono, monospace);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .wf-pipeline {
      flex-direction: column;
      align-items: stretch;
    }

    .wf-step {
      min-width: unset;
    }

    .wf-connector {
      align-self: flex-start;
      padding-left: 22px;
    }

    .wf-connector-line {
      width: 2px;
      height: 16px;
    }

    .wf-connector-line::after {
      right: -3px;
      top: auto;
      bottom: 0;
      border: 4px solid transparent;
      border-top: 5px solid var(--line);
      border-left: 4px solid transparent;
    }
  }
</style>
