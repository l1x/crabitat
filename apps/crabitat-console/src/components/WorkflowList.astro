---
import type { WorkflowRecord } from '../lib/types';
import StepPipeline from './StepPipeline.astro';
import type { PipelineStep } from './StepPipeline.astro';

interface Props {
  workflows: WorkflowRecord[];
}

const { workflows } = Astro.props;

function workflowToSteps(wf: WorkflowRecord): PipelineStep[] {
  return wf.steps.map((step) => ({
    label: step.step_id,
    position: step.position,
    prompt_file: step.prompt_file,
    depends_on: step.depends_on,
    condition: step.condition ?? undefined,
    max_retries: step.max_retries,
  }));
}
---

<div class="data-panel">
  <div class="data-panel-header">
    <span class="data-panel-title">Workflows</span>
    <span class="content-count">{workflows.length}</span>
  </div>
  <div class="data-panel-body">
    {workflows.length === 0 ? (
      <div class="empty-state">
        <div class="empty-state-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/>
            <path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/>
          </svg>
        </div>
        <div class="empty-state-title">No workflows</div>
        <p class="empty-state-desc">Workflows define step-by-step pipelines that missions follow.</p>
      </div>
    ) : (
      <div class="wf-list">
        {workflows.map((wf) => (
          <div class="wf-card">
            <div class="wf-card-top">
              <div class="wf-card-identity">
                <h3 class="wf-name">{wf.name}</h3>
                <div class="wf-badges">
                  <span class="wf-version">v{wf.version}</span>
                  <span class={`source-tag source-tag--${wf.source}`}>
                    {wf.source === 'toml' ? 'TOML' : 'Manual'}
                  </span>
                  {wf.commit_hash && (
                    <span class="wf-commit" title={wf.commit_hash}>
                      {wf.commit_hash.slice(0, 8)}
                    </span>
                  )}
                </div>
              </div>
              {wf.description && (
                <p class="wf-desc">{wf.description}</p>
              )}
            </div>

            <StepPipeline steps={workflowToSteps(wf)} />
          </div>
        ))}
      </div>
    )}
  </div>
</div>

<!-- Prompt preview modal -->
<dialog class="modal modal--wide" id="prompt-preview-modal">
  <div class="modal-content">
    <div class="modal-header">
      <span class="modal-title" id="prompt-modal-title">Prompt Preview</span>
      <button class="modal-close" id="prompt-modal-close">&times;</button>
    </div>
    <div class="modal-body">
      <div class="prompt-preview-content prompt-prose" id="prompt-modal-content">Loading...</div>
    </div>
  </div>
</dialog>

<script>
  import { marked } from 'marked';

  const modal = document.getElementById('prompt-preview-modal') as HTMLDialogElement;
  const modalTitle = document.getElementById('prompt-modal-title')!;
  const modalContent = document.getElementById('prompt-modal-content')!;
  const modalClose = document.getElementById('prompt-modal-close')!;

  modalClose.addEventListener('click', () => modal.close());
  modal.addEventListener('click', (e) => {
    if (e.target === modal) modal.close();
  });

  document.querySelectorAll('.wf-prompt-link').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      const path = (btn as HTMLElement).dataset.path;
      if (!path) return;

      modalTitle.textContent = path;
      modalContent.innerHTML = '<p style="color:var(--muted)">Loading\u2026</p>';
      modal.showModal();

      try {
        const res = await fetch(`/api/prompt-files/preview?path=${encodeURIComponent(path)}`);
        if (!res.ok) throw new Error(`${res.status}`);
        const data = await res.json();
        modalContent.innerHTML = marked.parse(data.content) as string;
      } catch {
        modalContent.innerHTML = '<p style="color:var(--bad, #dc2626)">Failed to load prompt file.</p>';
      }
    });
  });
</script>

<style>
  .wf-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .wf-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--panel);
    overflow: hidden;
  }

  .wf-card-top {
    padding: 16px 20px 12px;
    border-bottom: 1px solid var(--line-light);
  }

  .wf-card-identity {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }

  .wf-name {
    font-size: 15px;
    font-weight: 600;
    color: var(--ink);
  }

  .wf-badges {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .wf-version {
    font-size: 11px;
    font-weight: 600;
    color: var(--muted);
    background: var(--neutral-bg);
    padding: 2px 8px;
    border-radius: 4px;
    letter-spacing: 0.02em;
  }

  .source-tag {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 2px 6px;
    border-radius: 3px;
  }

  .source-tag--toml {
    background: #dbeafe;
    color: #1d4ed8;
  }

  .source-tag--manual {
    background: #f3e8ff;
    color: #7c3aed;
  }

  .wf-commit {
    font-size: 11px;
    font-family: var(--font-mono, monospace);
    color: var(--muted);
    background: var(--neutral-bg);
    padding: 2px 6px;
    border-radius: 3px;
    cursor: default;
  }

  .wf-desc {
    font-size: 13px;
    color: var(--muted);
    margin-top: 6px;
    line-height: 1.4;
  }

  /* Modal */
  .modal {
    border: none;
    border-radius: var(--radius-lg, 12px);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    padding: 0;
    max-width: 800px;
    width: 90vw;
    max-height: 80vh;
  }

  .modal::backdrop {
    background: rgba(0, 0, 0, 0.4);
  }

  .modal-content {
    display: flex;
    flex-direction: column;
    max-height: 80vh;
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid var(--line, #e5e7eb);
  }

  .modal-title {
    font-size: 14px;
    font-weight: 600;
    font-family: var(--font-mono, monospace);
    color: var(--ink, #111);
  }

  .modal-close {
    background: none;
    border: none;
    font-size: 20px;
    cursor: pointer;
    color: var(--muted, #6b7280);
    padding: 0 4px;
    line-height: 1;
  }

  .modal-close:hover {
    color: var(--ink, #111);
  }

  .modal-body {
    padding: 16px 20px;
    overflow-y: auto;
    flex: 1;
  }

  /* Prompt prose (rendered markdown) */
  .prompt-prose {
    font-size: 13px;
    line-height: 1.6;
    color: var(--ink, #111);
  }

  .prompt-prose :global(p) {
    margin: 0 0 8px;
  }

  .prompt-prose :global(p:last-child) {
    margin-bottom: 0;
  }

  .prompt-prose :global(h1),
  .prompt-prose :global(h2),
  .prompt-prose :global(h3),
  .prompt-prose :global(h4) {
    color: var(--ink, #111);
    font-weight: 700;
    margin: 16px 0 6px;
  }

  .prompt-prose :global(h1) { font-size: 17px; }
  .prompt-prose :global(h2) { font-size: 15px; }
  .prompt-prose :global(h3) { font-size: 14px; }
  .prompt-prose :global(h4) { font-size: 13px; }

  .prompt-prose :global(h1:first-child),
  .prompt-prose :global(h2:first-child),
  .prompt-prose :global(h3:first-child) {
    margin-top: 0;
  }

  .prompt-prose :global(ul),
  .prompt-prose :global(ol) {
    margin: 4px 0 8px;
    padding-left: 20px;
  }

  .prompt-prose :global(li) {
    margin-bottom: 2px;
  }

  .prompt-prose :global(code) {
    background: var(--neutral-bg, #f3f4f6);
    padding: 1px 5px;
    border-radius: 3px;
    font-size: 12px;
    font-family: var(--font-mono, monospace);
  }

  .prompt-prose :global(pre) {
    background: var(--neutral-bg, #f3f4f6);
    padding: 10px 12px;
    border-radius: 6px;
    overflow-x: auto;
    margin: 6px 0 8px;
  }

  .prompt-prose :global(pre code) {
    background: none;
    padding: 0;
  }

  .prompt-prose :global(blockquote) {
    border-left: 3px solid var(--line, #e5e7eb);
    margin: 6px 0;
    padding: 2px 12px;
    color: var(--muted, #6b7280);
  }

  .prompt-prose :global(a) {
    color: var(--primary, #2563eb);
    text-decoration: none;
  }

  .prompt-prose :global(a:hover) {
    text-decoration: underline;
  }

  .prompt-prose :global(hr) {
    border: none;
    border-top: 1px solid var(--line, #e5e7eb);
    margin: 10px 0;
  }

  .prompt-prose :global(table) {
    border-collapse: collapse;
    width: 100%;
    margin: 6px 0 8px;
    font-size: 12px;
  }

  .prompt-prose :global(th),
  .prompt-prose :global(td) {
    border: 1px solid var(--line, #e5e7eb);
    padding: 4px 8px;
    text-align: left;
  }

  .prompt-prose :global(th) {
    background: var(--neutral-bg, #f3f4f6);
    font-weight: 600;
  }

  .prompt-prose :global(strong) {
    font-weight: 700;
  }

</style>
