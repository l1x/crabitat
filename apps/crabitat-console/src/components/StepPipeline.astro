---
export interface PipelineStep {
  label: string;
  position: number;
  status?: string;
  prompt_file?: string;
  depends_on?: string[];
  condition?: string;
  max_retries?: number;
}

interface Props {
  steps: PipelineStep[];
}

const { steps } = Astro.props;

const STEP_COLORS = ['step--1', 'step--2', 'step--3', 'step--4', 'step--5'];

function stepColor(index: number): string {
  return STEP_COLORS[index % STEP_COLORS.length];
}

function stepBgClass(status?: string): string {
  if (!status) return '';
  switch (status) {
    case 'completed': return 'sp-step--completed';
    case 'running': return 'sp-step--running';
    case 'failed': return 'sp-step--failed';
    default: return '';
  }
}

function connectorDone(status?: string): boolean {
  return status === 'completed';
}
---

<div class="sp-pipeline">
  {steps.map((step, i) => (
    <>
      <div class:list={[
        'sp-step',
        step.condition ? 'sp-step--conditional' : '',
        stepBgClass(step.status),
      ]}>
        <div class={`sp-step-num ${stepColor(step.position)}`}>
          {step.position + 1}
        </div>
        <div class="sp-step-body">
          <div class="sp-step-header">
            <span class="sp-step-id">{step.label}</span>
          </div>
          {step.prompt_file && (
            <button class="sp-step-prompt wf-prompt-link" data-path={step.prompt_file}>
              <svg viewBox="0 0 16 16" width="11" height="11" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M10 1H4a1.5 1.5 0 00-1.5 1.5v11A1.5 1.5 0 004 15h8a1.5 1.5 0 001.5-1.5V5z"/>
                <polyline points="10 1 10 5 13 5"/>
              </svg>
              {step.prompt_file.split('/').pop()}
            </button>
          )}
          {step.depends_on && step.depends_on.length > 0 && (
            <div class="sp-step-deps">
              <svg class="sp-dep-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M2 8h12M10 4l4 4-4 4"/>
              </svg>
              after {step.depends_on.join(', ')}
            </div>
          )}
          {step.condition && (
            <div class="sp-step-cond">
              <svg class="sp-cond-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M8 2L14 8L8 14L2 8Z"/>
              </svg>
              {step.condition}
            </div>
          )}
          {step.max_retries != null && step.max_retries > 0 && (
            <div class="sp-step-retry">
              <svg class="sp-retry-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M2 8a6 6 0 0111.5-2.3M14 2v4h-4"/>
                <path d="M14 8a6 6 0 01-11.5 2.3M2 14v-4h4"/>
              </svg>
              {step.max_retries} retries
            </div>
          )}
        </div>
      </div>
      {i < steps.length - 1 && (
        <div class:list={['sp-connector', connectorDone(step.status) ? 'sp-connector--done' : '']}>
          <svg class="sp-connector-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/>
            <path d="m12 5 7 7-7 7"/>
          </svg>
        </div>
      )}
    </>
  ))}
</div>

<style>
  .sp-pipeline {
    padding: 16px 20px 20px;
    display: flex;
    align-items: center;
    gap: 0;
    overflow-x: auto;
  }

  .sp-step {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 14px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: #fff;
    min-width: 130px;
    flex-shrink: 0;
  }

  .sp-step--conditional {
    border-style: dashed;
    background: #fefce8;
  }

  /* Status background overrides */
  .sp-step--completed {
    border-color: var(--good);
    background: var(--good-bg);
  }

  .sp-step--running {
    border-color: var(--warn);
    background: var(--warn-bg);
  }

  .sp-step--failed {
    border-color: var(--bad);
    background: var(--bad-bg);
  }

  .sp-step-num {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .sp-step-num.step--1 { background: #ede9fe; color: #6d28d9; }
  .sp-step-num.step--2 { background: #dbeafe; color: #1d4ed8; }
  .sp-step-num.step--3 { background: #dcfce7; color: #16a34a; }
  .sp-step-num.step--4 { background: #fef3c7; color: #d97706; }
  .sp-step-num.step--5 { background: var(--neutral-bg); color: var(--muted); }

  .sp-step-body {
    min-width: 0;
  }

  .sp-step-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 2px;
  }

  .sp-step-id {
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
  }

  .sp-step-prompt {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    color: var(--primary, #2563eb);
    background: none;
    border: none;
    padding: 0;
    margin-top: 3px;
    cursor: pointer;
    font-family: inherit;
  }

  .sp-step-prompt:hover {
    text-decoration: underline;
  }

  .sp-step-prompt svg {
    opacity: 0.6;
  }

  .sp-step-deps,
  .sp-step-cond,
  .sp-step-retry {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    margin-top: 3px;
  }

  .sp-step-deps {
    color: var(--muted);
  }

  .sp-step-cond {
    color: #b45309;
    font-style: italic;
  }

  .sp-step-retry {
    color: var(--muted);
  }

  .sp-dep-icon,
  .sp-cond-icon,
  .sp-retry-icon {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
  }

  /* Connector arrow */
  .sp-connector {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    padding: 0 2px;
  }

  .sp-connector-arrow {
    width: 20px;
    height: 20px;
    color: var(--muted, #9ca3af);
  }

  .sp-connector--done .sp-connector-arrow {
    color: var(--good);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .sp-pipeline {
      flex-direction: column;
      align-items: stretch;
    }

    .sp-step {
      min-width: unset;
    }

    .sp-connector {
      align-self: center;
      padding: 2px 0;
    }

    .sp-connector-arrow {
      transform: rotate(90deg);
    }
  }
</style>
