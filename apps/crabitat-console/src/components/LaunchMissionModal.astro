---
import { listAllWorkflows, getWorkflow } from "../lib/api-client";
import type { WorkflowSummary, WorkflowDetail } from "../lib/types";

interface Props {
  repoId: string;
  issueNumber: number;
}

const { repoId, issueNumber } = Astro.props;

let workflows: WorkflowSummary[] = [];
let allDetails: WorkflowDetail[] = [];

try {
  workflows = await listAllWorkflows();
  allDetails = await Promise.all(workflows.map(w => getWorkflow(w.name)));
} catch (e) {
  console.error("Failed to load workflows for mission launcher", e);
}
---

<button class="launch-trigger" data-issue={issueNumber}>Launch</button>

<dialog class="launch-dialog" id={`launch-modal-${issueNumber}`}>
  <div class="modal-content">
    <div class="modal-header">
      <h2>Launch Mission — Issue #{issueNumber}</h2>
      <button class="close-x">✕</button>
    </div>
    <div class="divider"></div>

    <form class="launch-form">
      <div class="field">
        <label for="workflow-select">WORKFLOW</label>
        <select name="workflow_name" class="workflow-select" required>
          <option value="">Select a workflow...</option>
          {workflows.map(w => (
            <option value={w.name}>{w.name} — {w.description}</option>
          ))}
        </select>
      </div>

      <div class="field">
        <label for="flavor-select">FLAVOR</label>
        <select name="flavor_id" class="flavor-select">
          <option value="">Vanilla (No additional prompts)</option>
          <!-- populated dynamically via JS -->
        </select>
      </div>

      <div class="actions">
        <button type="button" class="cancel-btn">Cancel</button>
        <button type="submit" class="submit-btn">Start Mission</button>
      </div>
    </form>
  </div>
</dialog>

<script is:inline define:vars={{ allDetails, issueNumber, repoId }}>
  const dialog = document.getElementById(`launch-modal-${issueNumber}`);
  const trigger = document.querySelector(`.launch-trigger[data-issue="${issueNumber}"]`);
  const closeX = dialog.querySelector('.close-x');
  const cancelBtn = dialog.querySelector('.cancel-btn');
  const form = dialog.querySelector('.launch-form');
  const wfSelect = dialog.querySelector('.workflow-select');
  const fSelect = dialog.querySelector('.flavor-select');

  trigger.addEventListener('click', () => dialog.showModal());

  const close = () => {
    dialog.close();
    form.reset();
  };

  closeX.addEventListener('click', close);
  cancelBtn.addEventListener('click', close);
  dialog.addEventListener('click', (e) => {
    if (e.target === dialog) close();
  });

  // Dynamic flavor filtering
  wfSelect.addEventListener('change', () => {
    const wfName = wfSelect.value;
    const wfDetail = allDetails.find(d => d.name === wfName);
    
    // Clear current options keep first
    fSelect.innerHTML = '<option value="">Vanilla (No additional prompts)</option>';
    
    if (wfDetail && wfDetail.flavors) {
      wfDetail.flavors.forEach(f => {
        const opt = document.createElement('option');
        opt.value = f.flavor_id;
        opt.textContent = f.name;
        fSelect.appendChild(opt);
      });
    }
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const workflow_name = formData.get('workflow_name');
    const flavor_id = formData.get('flavor_id') || null;

    const submitBtn = form.querySelector('.submit-btn');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Launching...';

    try {
      const res = await fetch('http://localhost:3001/v1/missions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          repo_id: repoId,
          issue_number: issueNumber,
          workflow_name,
          flavor_id
        })
      });

      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.error || 'Failed to launch mission');
      }

      const mission = await res.json();
      window.location.href = `/missions/${mission.mission_id}`;
    } catch (err) {
      alert(err instanceof Error ? err.message : String(err));
      submitBtn.disabled = false;
      submitBtn.textContent = 'Start Mission';
    }
  });
</script>

<style>
  .launch-trigger {
    font-size: 14px;
    font-weight: 600;
    color: var(--heading);
    padding: 8px 24px;
    background: var(--btn-bg);
    border: 1px solid var(--btn-border);
    border-radius: 6px;
    transition: all 0.2s;
    cursor: pointer;
  }

  .launch-trigger:hover {
    border-color: var(--muted);
    background: #222;
  }

  .launch-dialog {
    background: transparent;
    border: none;
    padding: 0;
    max-width: 100vw;
    max-height: 100vh;
    margin: auto;
  }

  .launch-dialog::backdrop {
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(4px);
  }

  .modal-content {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 32px;
    width: 500px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  h2 {
    color: var(--heading);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .close-x {
    color: var(--faint);
    font-size: 18px;
    padding: 4px;
    cursor: pointer;
  }

  .close-x:hover {
    color: var(--heading);
  }

  .divider {
    height: 1px;
    background: var(--border-subtle);
    margin-bottom: 24px;
  }

  .field {
    margin-bottom: 24px;
  }

  label {
    display: block;
    color: var(--muted);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 10px;
  }

  select {
    width: 100%;
    padding: 12px 16px;
    background: var(--input-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--body);
    font-size: 15px;
    outline: none;
    transition: border-color 0.2s;
    appearance: none;
  }

  select:focus {
    border-color: var(--muted);
  }

  .actions {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    margin-top: 32px;
  }

  .cancel-btn, .submit-btn {
    padding: 10px 24px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    transition: all 0.2s;
    cursor: pointer;
  }

  .cancel-btn {
    color: var(--muted);
  }

  .cancel-btn:hover {
    color: var(--heading);
    background: rgba(255, 255, 255, 0.05);
  }

  .submit-btn {
    background: #d0d0d0;
    color: #000;
    border: 1px solid #d0d0d0;
  }

  .submit-btn:hover {
    background: #ffffff;
    border-color: #ffffff;
  }

  .submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>
