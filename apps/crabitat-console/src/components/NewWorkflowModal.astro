---
import type { Repo } from "../lib/types";

interface Props {
  repos: Repo[];
}

const { repos } = Astro.props;
---

<button class="trigger" id="open-wf-modal">+ New Workflow</button>

<dialog id="new-workflow-modal">
  <div class="modal-content">
    <h2>New Workflow</h2>
    <div class="divider"></div>
    <form id="workflow-form" method="POST" action="/api/workflows/create">
      <div class="field">
        <label for="wf-repo">REPO</label>
        <select id="wf-repo" name="repo_id" required>
          <option value="" disabled selected>Select a repo</option>
          {repos.map((r) => (
            <option value={r.repo_id}>{r.owner}/{r.name}</option>
          ))}
        </select>
      </div>
      <div class="field">
        <label for="wf-name">NAME</label>
        <input type="text" id="wf-name" name="name" required placeholder="implement-feature" />
      </div>
      <div class="field">
        <label for="wf-desc">DESCRIPTION</label>
        <input type="text" id="wf-desc" name="description" placeholder="End-to-end implementation workflow" />
      </div>

      <div class="field">
        <label>STEPS</label>
        <div id="steps-container">
          <div class="step-row" data-index="0">
            <input type="text" name="step_name_0" required placeholder="Step name" class="step-input" />
            <input type="text" name="step_prompt_0" required placeholder="Prompt template" class="step-input prompt" />
          </div>
        </div>
        <button type="button" id="add-step-btn" class="add-step">+ Add Step</button>
      </div>

      <div class="actions">
        <button type="button" class="cancel" id="close-wf-modal">Cancel</button>
        <button type="submit" class="submit">Create</button>
      </div>
    </form>
  </div>
</dialog>

<script>
  const openBtn = document.getElementById("open-wf-modal")!;
  const closeBtn = document.getElementById("close-wf-modal")!;
  const dialog = document.getElementById("new-workflow-modal") as HTMLDialogElement;

  openBtn.addEventListener("click", () => dialog.showModal());
  closeBtn.addEventListener("click", () => dialog.close());
  dialog.addEventListener("click", (e) => {
    if (e.target === dialog) dialog.close();
  });

  let stepCount = 1;
  const addStepBtn = document.getElementById("add-step-btn")!;
  const container = document.getElementById("steps-container")!;

  addStepBtn.addEventListener("click", () => {
    const row = document.createElement("div");
    row.className = "step-row";
    row.dataset.index = String(stepCount);
    row.innerHTML = `
      <input type="text" name="step_name_${stepCount}" required placeholder="Step name" class="step-input" />
      <input type="text" name="step_prompt_${stepCount}" required placeholder="Prompt template" class="step-input prompt" />
    `;
    container.appendChild(row);
    stepCount++;
  });
</script>

<style>
  .trigger {
    padding: 8px 20px;
    border: 1px solid var(--btn-border);
    border-radius: 6px;
    color: #aaa;
    font-size: 12px;
    font-weight: 500;
    transition: border-color 0.15s;
  }

  .trigger:hover {
    border-color: var(--muted);
  }

  dialog {
    background: transparent;
    border: none;
    padding: 0;
    max-width: 100vw;
    max-height: 100vh;
  }

  dialog::backdrop {
    background: rgba(0, 0, 0, 0.7);
  }

  .modal-content {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
    width: 480px;
  }

  h2 {
    color: var(--heading);
    font-size: 16px;
    font-weight: 600;
  }

  .divider {
    height: 1px;
    background: var(--border-subtle);
    margin: 12px 0 16px;
  }

  .field {
    margin-bottom: 16px;
  }

  label {
    display: block;
    color: var(--muted);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.8px;
    margin-bottom: 6px;
  }

  input,
  select {
    width: 100%;
    padding: 8px 12px;
    background: var(--input-bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--body);
    font-size: 12px;
    font-family: inherit;
    outline: none;
    transition: border-color 0.15s;
  }

  input:focus,
  select:focus {
    border-color: var(--accent);
  }

  input::placeholder {
    color: var(--muted);
  }

  select option {
    background: var(--card);
    color: var(--body);
  }

  .step-row {
    display: flex;
    gap: 8px;
    margin-bottom: 8px;
  }

  .step-input {
    flex: 1;
  }

  .step-input.prompt {
    flex: 2;
  }

  .add-step {
    color: #555;
    font-size: 11px;
    border: 1px dashed #333;
    border-radius: 4px;
    padding: 4px 12px;
    transition: color 0.15s;
  }

  .add-step:hover {
    color: #aaa;
  }

  .actions {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    margin-top: 20px;
  }

  .cancel,
  .submit {
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 500;
  }

  .cancel {
    color: var(--muted);
  }

  .cancel:hover {
    color: var(--body);
  }

  .submit {
    border: 1px solid var(--btn-border);
    color: #aaa;
    transition: border-color 0.15s;
  }

  .submit:hover {
    border-color: var(--muted);
  }
</style>
