---
---

<button class="trigger" id="open-modal">+ Add Repo</button>

<dialog id="add-repo-modal">
  <div class="modal-content">
    <h2>Add Repository</h2>
    <div class="divider"></div>
    <form method="POST" action="/api/repos/create">
      <div class="field">
        <label for="owner">OWNER</label>
        <input type="text" id="owner" name="owner" required placeholder="acme" />
      </div>
      <div class="field">
        <label for="name">NAME</label>
        <input type="text" id="name" name="name" required placeholder="my-repo" />
      </div>
      <div class="field">
        <label for="local_path">LOCAL PATH</label>
        <input
          type="text"
          id="local_path"
          name="local_path"
          required
          placeholder="/Users/dev/code/my-repo"
        />
      </div>
      <div class="actions">
        <button type="button" class="cancel" id="close-modal">Cancel</button>
        <button type="submit" class="submit">Add Repo</button>
      </div>
    </form>
  </div>
</dialog>

<script>
  const openBtn = document.getElementById("open-modal")!;
  const closeBtn = document.getElementById("close-modal")!;
  const dialog = document.getElementById("add-repo-modal") as HTMLDialogElement;

  openBtn.addEventListener("click", () => dialog.showModal());
  closeBtn.addEventListener("click", () => dialog.close());
  dialog.addEventListener("click", (e) => {
    if (e.target === dialog) dialog.close();
  });
</script>

<style>
  .trigger {
    padding: 8px 20px;
    border: 1px solid var(--btn-border);
    border-radius: 6px;
    color: #aaa;
    font-size: 12px;
    font-weight: 500;
    transition: border-color 0.15s;
  }

  .trigger:hover {
    border-color: var(--muted);
  }

  dialog {
    background: transparent;
    border: none;
    padding: 0;
    max-width: 100vw;
    max-height: 100vh;
  }

  dialog::backdrop {
    background: rgba(0, 0, 0, 0.7);
  }

  .modal-content {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
    width: 400px;
  }

  h2 {
    color: var(--heading);
    font-size: 16px;
    font-weight: 600;
  }

  .divider {
    height: 1px;
    background: var(--border-subtle);
    margin: 12px 0 16px;
  }

  .field {
    margin-bottom: 16px;
  }

  label {
    display: block;
    color: var(--muted);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.8px;
    margin-bottom: 6px;
  }

  input {
    width: 100%;
    padding: 8px 12px;
    background: var(--input-bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--body);
    font-size: 12px;
    font-family: inherit;
    outline: none;
    transition: border-color 0.15s;
  }

  input:focus {
    border-color: var(--accent);
  }

  input::placeholder {
    color: var(--muted);
  }

  .actions {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    margin-top: 20px;
  }

  .cancel,
  .submit {
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 500;
  }

  .cancel {
    color: var(--muted);
  }

  .cancel:hover {
    color: var(--body);
  }

  .submit {
    border: 1px solid var(--btn-border);
    color: #aaa;
    transition: border-color 0.15s;
  }

  .submit:hover {
    border-color: var(--muted);
  }
</style>
