---
---

<button class="trigger" id="open-modal">+ Add Repo</button>

<dialog id="add-repo-modal">
  <div class="modal-content">
    <div class="modal-header">
      <h2>Add Repository</h2>
      <button class="close-x" id="close-modal-x">✕</button>
    </div>
    <div class="divider"></div>
    <form id="add-repo-form">
      <input type="hidden" id="hidden-owner" name="owner" />
      <input type="hidden" id="hidden-name" name="name" />
      
      <div class="field">
        <label for="repo-search">GITHUB REPOSITORY</label>
        <div class="autocomplete-wrapper">
          <input
            type="text"
            id="repo-search"
            placeholder="owner/repo"
            autocomplete="off"
            required
          />
          <ul id="repo-suggestions" class="suggestions"></ul>
        </div>
      </div>

      <div class="field">
        <label for="local_path">LOCAL FILESYSTEM PATH</label>
        <div class="autocomplete-wrapper">
          <input
            type="text"
            id="local_path"
            name="local_path"
            required
            placeholder="/Users/dev/code/my-repo"
            autocomplete="off"
          />
          <ul id="path-suggestions" class="suggestions"></ul>
        </div>
      </div>

      <div class="actions">
        <button type="button" class="cancel" id="close-modal-btn">Cancel</button>
        <button type="submit" class="submit" id="submit-repo">Add Repository</button>
      </div>
    </form>
  </div>
</dialog>

<script>
  import { listDirs, searchGithubRepos } from "../lib/api-client";

  const dialog = document.getElementById("add-repo-modal") as HTMLDialogElement;
  const openBtn = document.getElementById("open-modal")!;
  const closeX = document.getElementById("close-modal-x")!;
  const closeBtn = document.getElementById("close-modal-btn")!;
  const form = document.getElementById("add-repo-form") as HTMLFormElement;
  
  const searchInput = document.getElementById("repo-search") as HTMLInputElement;
  const repoSuggestions = document.getElementById("repo-suggestions")!;
  const hiddenOwner = document.getElementById("hidden-owner") as HTMLInputElement;
  const hiddenName = document.getElementById("hidden-name") as HTMLInputElement;

  const pathInput = document.getElementById("local_path") as HTMLInputElement;
  const pathSuggestions = document.getElementById("path-suggestions")!;

  openBtn.addEventListener("click", () => dialog.showModal());
  
  const close = () => {
    dialog.close();
    form.reset();
    repoSuggestions.innerHTML = "";
    pathSuggestions.innerHTML = "";
  };

  closeX.addEventListener("click", close);
  closeBtn.addEventListener("click", close);
  dialog.addEventListener("click", (e) => {
    if (e.target === dialog) close();
  });

  let repoDebounce: ReturnType<typeof setTimeout>;
  let pathDebounce: ReturnType<typeof setTimeout>;

  // Github Repo Search
  searchInput.addEventListener("input", () => {
    const q = searchInput.value.trim();
    hiddenOwner.value = "";
    hiddenName.value = "";

    clearTimeout(repoDebounce);
    if (q.length < 2) {
      repoSuggestions.innerHTML = "";
      return;
    }

    repoDebounce = setTimeout(async () => {
      try {
        const repos = await searchGithubRepos(q);
        repoSuggestions.innerHTML = "";
        repos.forEach(repo => {
          const li = document.createElement("li");
          li.textContent = repo.nameWithOwner;
          li.addEventListener("click", () => {
            searchInput.value = repo.nameWithOwner;
            const [owner, name] = repo.nameWithOwner.split("/");
            hiddenOwner.value = owner;
            hiddenName.value = name;
            repoSuggestions.innerHTML = "";
          });
          repoSuggestions.appendChild(li);
        });
      } catch {}
    }, 300);
  });

  // Local Path Search
  pathInput.addEventListener("input", () => {
    const q = pathInput.value.trim();
    clearTimeout(pathDebounce);
    
    if (q.length < 1) {
      pathSuggestions.innerHTML = "";
      return;
    }

    pathDebounce = setTimeout(async () => {
      try {
        const dirs = await listDirs(q);
        pathSuggestions.innerHTML = "";
        dirs.forEach(dir => {
          const li = document.createElement("li");
          li.textContent = dir;
          li.addEventListener("click", () => {
            pathInput.value = dir;
            pathSuggestions.innerHTML = "";
          });
          pathSuggestions.appendChild(li);
        });
      } catch {}
    }, 200);
  });

  // Form Submit
  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const owner = hiddenOwner.value;
    const name = hiddenName.value;
    const local_path = pathInput.value.trim();

    if (!owner || !name || !local_path) {
      alert("Please select a repository from the suggestions and provide a local path.");
      return;
    }

    const submitBtn = document.getElementById("submit-repo") as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = "Adding...";

    try {
      const res = await fetch("http://localhost:3001/v1/repos", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ owner, name, local_path }),
      });
      
      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.error || "Failed to add repository");
      }

      window.location.reload();
    } catch (err) {
      alert(err instanceof Error ? err.message : String(err));
      submitBtn.disabled = false;
      submitBtn.textContent = "Add Repository";
    }
  });

  // Close suggestions on outside click
  document.addEventListener("click", (e) => {
    if (!(e.target as Element).closest(".autocomplete-wrapper")) {
      repoSuggestions.innerHTML = "";
      pathSuggestions.innerHTML = "";
    }
  });
</script>

<style>
  .trigger {
    padding: 10px 24px;
    background: var(--btn-bg);
    border: 1px solid var(--btn-border);
    color: var(--heading);
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    transition: all 0.2s;
  }

  .trigger:hover {
    background: var(--btn-hover-bg);
    border-color: var(--muted);
  }

  dialog {
    background: transparent;
    border: none;
    padding: 0;
    max-width: 100vw;
    max-height: 100vh;
    margin: auto;
  }

  dialog::backdrop {
    background: var(--backdrop);
    backdrop-filter: blur(4px);
  }

  .modal-content {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 32px;
    width: 500px;
    box-shadow: 0 20px 40px var(--shadow-card);
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  h2 {
    color: var(--heading);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .close-x {
    color: var(--faint);
    font-size: 18px;
    padding: 4px;
    cursor: pointer;
  }

  .close-x:hover {
    color: var(--heading);
  }

  .divider {
    height: 1px;
    background: var(--border-subtle);
    margin-bottom: 24px;
  }

  .field {
    margin-bottom: 24px;
  }

  label {
    display: block;
    color: var(--muted);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 10px;
  }

  .autocomplete-wrapper {
    position: relative;
  }

  input {
    width: 100%;
    padding: 12px 16px;
    background: var(--input-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--body);
    font-size: 15px;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
  }

  input:focus {
    border-color: var(--muted);
  }

  input::placeholder {
    color: var(--muted);
  }

  .suggestions {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    list-style: none;
    background: var(--card);
    border: 1px solid var(--border);
    border-top: none;
    border-radius: 0 0 8px 8px;
    max-height: 200px;
    overflow-y: auto;
    z-index: 100;
    box-shadow: 0 10px 20px var(--shadow-card);
  }

  .suggestions:empty {
    display: none;
  }

  .suggestions :global(li) {
    padding: 10px 16px;
    font-size: 14px;
    font-family: monospace;
    color: var(--body);
    cursor: pointer;
    border-bottom: 1px solid var(--border-subtle);
  }

  .suggestions :global(li:last-child) {
    border-bottom: none;
  }

  .suggestions :global(li:hover) {
    background: var(--overlay-medium);
    color: var(--heading);
  }

  .actions {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    margin-top: 32px;
  }

  .cancel,
  .submit {
    padding: 10px 24px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    transition: all 0.2s;
  }

  .cancel {
    color: var(--muted);
  }

  .cancel:hover {
    color: var(--heading);
    background: var(--overlay-medium);
  }

  .submit {
    background: var(--primary-bg);
    color: var(--primary-text);
    border: 1px solid var(--primary-bg);
  }

  .submit:hover {
    background: var(--primary-hover);
    border-color: var(--primary-hover);
  }

  .submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>
