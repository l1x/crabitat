---
---

<button class="trigger" id="open-modal">+ Add Repo</button>

<dialog id="add-repo-modal">
  <div class="modal-content">
    <h2>Add Repository</h2>
    <div class="divider"></div>
    <form method="POST" action="/api/repos/create">
      <input type="hidden" id="hidden-owner" name="owner" />
      <input type="hidden" id="hidden-name" name="name" />
      <div class="field">
        <label for="repo-search">REPO</label>
        <div class="autocomplete-wrapper">
          <input
            type="text"
            id="repo-search"
            placeholder="owner/repo"
            autocomplete="off"
            required
          />
          <ul id="repo-suggestions" class="suggestions"></ul>
        </div>
      </div>
      <div class="field">
        <label for="local_path">LOCAL PATH</label>
        <input
          type="text"
          id="local_path"
          name="local_path"
          required
          placeholder="/Users/dev/code/my-repo"
        />
      </div>
      <div class="actions">
        <button type="button" class="cancel" id="close-modal">Cancel</button>
        <button type="submit" class="submit">Add Repo</button>
      </div>
    </form>
  </div>
</dialog>

<script>
  const openBtn = document.getElementById("open-modal")!;
  const closeBtn = document.getElementById("close-modal")!;
  const dialog = document.getElementById("add-repo-modal") as HTMLDialogElement;
  const searchInput = document.getElementById("repo-search") as HTMLInputElement;
  const suggestions = document.getElementById("repo-suggestions")!;
  const hiddenOwner = document.getElementById("hidden-owner") as HTMLInputElement;
  const hiddenName = document.getElementById("hidden-name") as HTMLInputElement;

  openBtn.addEventListener("click", () => dialog.showModal());
  closeBtn.addEventListener("click", () => dialog.close());
  dialog.addEventListener("click", (e) => {
    if (e.target === dialog) dialog.close();
  });

  let debounceTimer: ReturnType<typeof setTimeout>;

  searchInput.addEventListener("input", () => {
    const q = searchInput.value.trim();
    // Clear hidden fields when user edits
    hiddenOwner.value = "";
    hiddenName.value = "";

    clearTimeout(debounceTimer);
    if (q.length < 2) {
      suggestions.innerHTML = "";
      return;
    }

    debounceTimer = setTimeout(async () => {
      try {
        const res = await fetch(`http://localhost:3001/v1/github/repos?q=${encodeURIComponent(q)}`);
        if (!res.ok) return;
        const repos: { nameWithOwner: string }[] = await res.json();
        suggestions.innerHTML = "";
        for (const repo of repos) {
          const li = document.createElement("li");
          li.textContent = repo.nameWithOwner;
          li.addEventListener("click", () => selectRepo(repo.nameWithOwner));
          suggestions.appendChild(li);
        }
      } catch {
        // Silently ignore search errors
      }
    }, 250);
  });

  function selectRepo(nameWithOwner: string) {
    searchInput.value = nameWithOwner;
    suggestions.innerHTML = "";
    const [owner, name] = nameWithOwner.split("/");
    hiddenOwner.value = owner;
    hiddenName.value = name;
  }

  // Close suggestions when clicking outside
  document.addEventListener("click", (e) => {
    if (!(e.target as Element).closest(".autocomplete-wrapper")) {
      suggestions.innerHTML = "";
    }
  });
</script>

<style>
  .trigger {
    padding: 8px 20px;
    border: 1px solid var(--btn-border);
    border-radius: 6px;
    color: var(--body);
    font-size: 12px;
    font-weight: 500;
    transition: border-color 0.15s;
  }

  .trigger:hover {
    border-color: var(--muted);
  }

  dialog {
    background: transparent;
    border: none;
    padding: 0;
    max-width: 100vw;
    max-height: 100vh;
    margin: auto;
  }

  dialog::backdrop {
    background: rgba(0, 0, 0, 0.7);
  }

  .modal-content {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
    width: 400px;
  }

  h2 {
    color: var(--heading);
    font-size: 16px;
    font-weight: 600;
  }

  .divider {
    height: 1px;
    background: var(--border-subtle);
    margin: 12px 0 16px;
  }

  .field {
    margin-bottom: 16px;
  }

  label {
    display: block;
    color: var(--muted);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.8px;
    margin-bottom: 6px;
  }

  .autocomplete-wrapper {
    position: relative;
  }

  input {
    width: 100%;
    padding: 8px 12px;
    background: var(--input-bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--body);
    font-size: 12px;
    font-family: inherit;
    outline: none;
    transition: border-color 0.15s;
  }

  input:focus {
    border-color: var(--accent);
  }

  input::placeholder {
    color: var(--muted);
  }

  .suggestions {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    list-style: none;
    background: var(--card);
    border: 1px solid var(--border);
    border-top: none;
    border-radius: 0 0 4px 4px;
    max-height: 180px;
    overflow-y: auto;
    z-index: 20;
  }

  .suggestions:empty {
    display: none;
  }

  .suggestions :global(li) {
    padding: 6px 12px;
    font-size: 12px;
    color: var(--heading);
    cursor: pointer;
    transition: background 0.1s;
  }

  .suggestions :global(li:hover) {
    background: rgba(255, 255, 255, 0.08);
  }

  .actions {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    margin-top: 20px;
  }

  .cancel,
  .submit {
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 500;
  }

  .cancel {
    color: var(--muted);
  }

  .cancel:hover {
    color: var(--body);
  }

  .submit {
    border: 1px solid var(--btn-border);
    color: var(--body);
    transition: border-color 0.15s;
  }

  .submit:hover {
    border-color: var(--muted);
  }
</style>
