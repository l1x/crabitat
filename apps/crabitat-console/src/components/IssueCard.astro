---
import { marked } from 'marked';
import type { Issue } from "../lib/types";

interface Props {
  issue: Issue;
}

const { issue } = Astro.props;

// Render markdown to HTML for the full view
const renderedBody = issue.body ? marked.parse(issue.body) : "";

// Truncated version for the preview (plain text)
function getPreview(text: string | null): string {
  if (!text) return "";
  const plainText = text.replace(/[#*`_~\[\]\n]/g, ' '); // strip some basic md and newlines
  return plainText.slice(0, 160).trim() + (plainText.length > 160 ? "..." : "");
}
---

<div class="issue-card" data-issue-number={issue.number}>
  <div class="row">
    <div class="left">
      <span class={`dot ${issue.state.toLowerCase() === "open" ? "open" : "closed"}`}></span>
      <span class="number">#{issue.number}</span>
      <span class="title" title={issue.title}>{issue.title}</span>
    </div>
    <div class="actions">
      {issue.body && (
        <button class="expand-btn" title="Toggle full body">...</button>
      )}
      <button class="launch-btn">Launch</button>
    </div>
  </div>

  <div class="details">
    {issue.labels.length > 0 && (
      <div class="labels">
        {issue.labels.map((label) => (
          <span class="pill">{label}</span>
        ))}
      </div>
    )}

    {issue.body && (
      <div class="body-container">
        <p class="body-preview">{getPreview(issue.body)}</p>
        <div class="body-full markdown-body hidden" set:html={renderedBody}></div>
      </div>
    )}
  </div>
</div>

<script>
  // Robust event delegation for all issue cards
  document.addEventListener('click', (e) => {
    const btn = (e.target as Element).closest('.expand-btn');
    if (!btn) return;

    const card = btn.closest('.issue-card');
    if (!card) return;

    const preview = card.querySelector('.body-preview');
    const full = card.querySelector('.body-full');

    if (preview && full) {
      const isHidden = full.classList.contains('hidden');
      if (isHidden) {
        full.classList.remove('hidden');
        preview.classList.add('hidden');
        btn.textContent = '✕';
      } else {
        full.classList.add('hidden');
        preview.classList.remove('hidden');
        btn.textContent = '...';
      }
    }
  });
</script>

<style is:global>
  /* Base markdown styling for inside the card */
  .markdown-body {
    color: var(--body);
    font-size: 15px;
    line-height: 1.6;
    overflow-wrap: break-word;
  }

  .markdown-body h1, .markdown-body h2, .markdown-body h3 {
    color: var(--heading);
    margin-top: 16px;
    margin-bottom: 8px;
    font-weight: 600;
  }

  .markdown-body h1 { font-size: 1.4em; }
  .markdown-body h2 { font-size: 1.25em; }
  .markdown-body h3 { font-size: 1.1em; }

  .markdown-body p { margin-bottom: 12px; }
  
  .markdown-body ul, .markdown-body ol {
    margin-bottom: 12px;
    padding-left: 20px;
  }

  .markdown-body li { margin-bottom: 4px; }

  .markdown-body code {
    font-family: monospace;
    background: rgba(255, 255, 255, 0.05);
    padding: 2px 4px;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .markdown-body pre {
    background: #0f0f0f;
    padding: 16px;
    border-radius: 8px;
    border: 1px solid var(--border-subtle);
    margin-bottom: 16px;
    overflow-x: auto;
  }

  .markdown-body pre code {
    background: none;
    padding: 0;
  }

  .markdown-body blockquote {
    border-left: 4px solid var(--border-subtle);
    padding-left: 16px;
    color: var(--muted);
    margin-bottom: 12px;
  }
</style>

<style>
  .issue-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: border-color 0.2s;
    max-width: 1000px;
  }

  .issue-card:hover {
    border-color: #333;
  }

  .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .left {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .dot.open { background: #3fb950; box-shadow: 0 0 8px rgba(63, 185, 80, 0.4); }
  .dot.closed { background: #8b949e; }

  .number {
    color: var(--muted);
    font-size: 15px;
    font-weight: 600;
    font-family: monospace;
    flex-shrink: 0;
  }

  .title {
    color: var(--heading);
    font-size: 18px;
    font-weight: 700;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    letter-spacing: -0.3px;
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .expand-btn {
    color: var(--muted);
    font-size: 18px;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 6px;
    transition: all 0.2s;
    line-height: 1;
    background: transparent;
    border: none;
    cursor: pointer;
  }

  .expand-btn:hover {
    background: rgba(255, 255, 255, 0.05);
    color: var(--heading);
  }

  .launch-btn {
    font-size: 14px;
    font-weight: 600;
    color: var(--heading);
    padding: 8px 24px;
    background: var(--btn-bg);
    border: 1px solid var(--btn-border);
    border-radius: 6px;
    transition: all 0.2s;
    cursor: pointer;
  }

  .launch-btn:hover {
    border-color: var(--muted);
    background: #222;
  }

  .details {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-left: 22px;
  }

  .labels {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .pill {
    font-size: 12px;
    font-weight: 600;
    color: var(--body);
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--btn-border);
    border-radius: 12px;
    padding: 2px 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .body-container {
    line-height: 1.6;
  }

  .body-preview {
    color: var(--muted);
    font-size: 14px;
    margin: 0;
  }

  .body-full {
    animation: slideDown 0.2s ease-out;
  }

  .hidden {
    display: none !important;
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
