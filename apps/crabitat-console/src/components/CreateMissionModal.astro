---
import type { RepoRecord, WorkflowRecord } from '../lib/types';

interface Props {
  repos: RepoRecord[];
  workflows: WorkflowRecord[];
}

const { repos, workflows } = Astro.props;
---

<dialog class="modal modal--wide" id="create-mission-modal">
  <div class="modal-content">
    <div class="modal-header">
      <span class="modal-title">Create Mission</span>
      <button class="modal-close" id="create-mission-close">&times;</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label" for="mission-repo">Repository</label>
        <select class="form-input" id="mission-repo">
          {repos.map((r) => (
            <option value={r.repo_id}>{r.full_name}</option>
          ))}
        </select>
      </div>

      <div class="form-group">
        <label class="form-label" for="mission-prompt">Prompt</label>
        <textarea
          class="form-input"
          id="mission-prompt"
          rows="4"
          placeholder="Describe what this mission should accomplish..."
        ></textarea>
      </div>

      <div class="form-group">
        <label class="form-label" for="mission-workflow">Workflow (optional)</label>
        <select class="form-input" id="mission-workflow">
          <option value="">None</option>
          {workflows.map((wf) => (
            <option value={wf.name}>{wf.name}</option>
          ))}
        </select>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn" id="create-mission-cancel">Cancel</button>
      <button class="btn btn--primary" id="create-mission-submit">Create</button>
    </div>
  </div>
</dialog>

<script id="create-mission-repos-json" type="application/json" set:html={JSON.stringify(repos.map((r) => ({ repo_id: r.repo_id, stacks: r.stacks ?? [] })))} />
<script id="create-mission-workflows-json" type="application/json" set:html={JSON.stringify(workflows.map((wf) => ({ name: wf.name, source: wf.source })))} />

<script>
  const modal = document.getElementById('create-mission-modal') as HTMLDialogElement;
  const closeBtn = document.getElementById('create-mission-close')!;
  const cancelBtn = document.getElementById('create-mission-cancel')!;
  const submitBtn = document.getElementById('create-mission-submit') as HTMLButtonElement;

  const repoSelect = document.getElementById('mission-repo') as HTMLSelectElement;
  const promptInput = document.getElementById('mission-prompt') as HTMLTextAreaElement;
  const workflowSelect = document.getElementById('mission-workflow') as HTMLSelectElement;

  interface RepoMeta { repo_id: string; stacks: string[]; }
  interface WfMeta { name: string; source: string; }

  const repoMetas: RepoMeta[] = JSON.parse(document.getElementById('create-mission-repos-json')?.textContent || '[]');
  const allWorkflows: WfMeta[] = JSON.parse(document.getElementById('create-mission-workflows-json')?.textContent || '[]');

  function filterWorkflows() {
    const repoId = repoSelect.value;
    const repoMeta = repoMetas.find((r) => r.repo_id === repoId);
    const stacks = repoMeta?.stacks ?? [];

    // Compute expected assembled suffix
    const sorted = [...stacks].sort();
    const suffix = sorted.join('+');

    // Filter: show assembled workflows matching this repo's stacks, plus base workflows as fallback
    const filtered = allWorkflows.filter((wf) => {
      if (!wf.name.includes('/')) return true; // base workflow
      if (stacks.length === 0) return false; // no stacks → hide assembled
      return wf.name.endsWith('/' + suffix);
    });

    // Rebuild options
    workflowSelect.innerHTML = '<option value="">None</option>' +
      filtered.map((wf) => `<option value="${wf.name}">${wf.name}</option>`).join('');
  }

  repoSelect.addEventListener('change', filterWorkflows);

  function resetModal() {
    repoSelect.selectedIndex = 0;
    promptInput.value = '';
    filterWorkflows();
    submitBtn.textContent = 'Create';
    submitBtn.disabled = false;
  }

  closeBtn.addEventListener('click', () => { modal.close(); resetModal(); });
  cancelBtn.addEventListener('click', () => { modal.close(); resetModal(); });
  modal.addEventListener('click', (e) => {
    if (e.target === modal) { modal.close(); resetModal(); }
  });

  submitBtn.addEventListener('click', async () => {
    const prompt = promptInput.value.trim();
    if (!prompt) {
      alert('Prompt is required.');
      return;
    }

    const repoId = repoSelect.value;
    if (!repoId) {
      alert('Repository is required.');
      return;
    }

    submitBtn.textContent = 'Creating...';
    submitBtn.disabled = true;

    try {
      const body: Record<string, string> = { repo_id: repoId, prompt };
      const workflow = workflowSelect.value;
      if (workflow) body.workflow = workflow;

      const res = await fetch('/api/missions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: 'Unknown error' }));
        throw new Error(err.error || `Failed to create mission: ${res.status}`);
      }

      modal.close();
      resetModal();
      window.location.reload();
    } catch (e: unknown) {
      submitBtn.textContent = 'Create';
      submitBtn.disabled = false;
      alert(`Error: ${e instanceof Error ? e.message : e}`);
    }
  });

  (window as any).openCreateMissionModal = () => {
    resetModal();
    modal.showModal();
    promptInput.focus();
  };
</script>
