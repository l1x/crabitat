---
import { listPromptFiles } from "../lib/api-client";
import type { WorkflowFlavor } from "../lib/types";

interface Props {
  flavor: WorkflowFlavor;
}

const { flavor } = Astro.props;

let promptFiles: string[] = [];
try {
  promptFiles = await listPromptFiles();
} catch (e) {
  console.error("Failed to list prompt files", e);
}
---

<div class="flavor-pill-wrapper">
  <button class="pill-btn detail-trigger" data-flavor-id={flavor.flavor_id} title={flavor.prompt_paths.join('\n')}>
    <span class="flavor-name">{flavor.name}</span>
    <span class="flavor-count">{flavor.prompt_paths.length}</span>
  </button>
  <button class="delete-flavor-btn" data-flavor-id={flavor.flavor_id} title="Delete flavor">✕</button>
</div>

<dialog class="detail-dialog" id={`detail-modal-${flavor.flavor_id}`}>
  <div class="modal-content">
    <div class="modal-header">
      <div class="title-row">
        <h2 id="modal-title">{flavor.name}</h2>
        <button type="button" class="edit-btn-inline" title="Edit flavor">✎</button>
      </div>
      <button class="close-x">✕</button>
    </div>
    
    <div class="divider"></div>

    <div id={`error-${flavor.flavor_id}`} class="modal-error hidden"></div>

    <!-- View/Preview Mode -->
    <div class="view-mode">
      <div class="field">
        <label>INCLUDED PROMPTS</label>
        <ul class="path-list">
          {flavor.prompt_paths.map(p => (
            <li><code>{p}</code></li>
          ))}
        </ul>
      </div>

      <div class="field">
        <label>PREVIEW CONTENT</label>
        <div class="preview-box">
          <div class="preview-text markdown-body">Loading preview...</div>
        </div>
      </div>

      <div class="actions">
        <button type="button" class="close-btn">Close</button>
      </div>
    </div>

    <!-- Edit Mode (hidden by default) -->
    <form class="edit-mode hidden">
      <div class="field">
        <label for={`edit-name-${flavor.flavor_id}`}>FLAVOR NAME</label>
        <input type="text" name="name" id={`edit-name-${flavor.flavor_id}`} value={flavor.name} required />
      </div>

      <div class="field">
        <label>PROMPT FILES</label>
        <div class="prompt-picker">
          {promptFiles.map((file) => (
            <label class="prompt-item">
              <input type="checkbox" name="prompts" value={file} checked={flavor.prompt_paths.includes(file)} />
              <span class="file-path">{file}</span>
            </label>
          ))}
        </div>
      </div>

      <div class="actions">
        <button type="button" class="cancel-edit-btn">Cancel</button>
        <button type="submit" class="save-btn">Save Changes</button>
      </div>
    </form>
  </div>
</dialog>

<script is:inline define:vars={{ flavor }}>
  const dialog = document.getElementById(`detail-modal-${flavor.flavor_id}`);
  const trigger = document.querySelector(`.detail-trigger[data-flavor-id="${flavor.flavor_id}"]`);
  const deleteBtn = document.querySelector(`.delete-flavor-btn[data-flavor-id="${flavor.flavor_id}"]`);
  const closeX = dialog.querySelector('.close-x');
  const closeBtn = dialog.querySelector('.close-btn');
  const editBtn = dialog.querySelector('.edit-btn-inline');
  const cancelEditBtn = dialog.querySelector('.cancel-edit-btn');
  const viewMode = dialog.querySelector('.view-mode');
  const editMode = dialog.querySelector('.edit-mode');
  const previewText = dialog.querySelector('.preview-text');
  const errorEl = dialog.querySelector(`#error-${flavor.flavor_id}`);

  trigger.addEventListener('click', async () => {
    dialog.showModal();
    previewText.textContent = "Loading preview...";
    errorEl.classList.add('hidden');
    errorEl.textContent = '';

    try {
      if (flavor.prompt_paths && flavor.prompt_paths.length > 0) {
        const res = await fetch(`http://localhost:3001/v1/prompts/content`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ paths: flavor.prompt_paths })
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = await res.json();
        
        if (typeof window.marked !== 'undefined') {
          previewText.innerHTML = window.marked.parse(data.content || "Empty fragments.");
        } else {
          previewText.textContent = data.content || "Empty fragments.";
        }
      } else {
        previewText.textContent = "No prompt fragments selected.";
      }
    } catch (e) {
      previewText.textContent = `Error loading preview: ${e.message}`;
    }
  });

  deleteBtn?.addEventListener('click', async (e) => {
    e.stopPropagation();
    if (confirm(`Are you sure you want to delete the flavor '${flavor.name}'?`)) {
      try {
        const res = await fetch(`http://localhost:3001/v1/workflows/${flavor.workflow_name}/flavors/${flavor.flavor_id}`, {
          method: 'DELETE'
        });
        if (!res.ok) throw new Error('Failed to delete flavor');
        window.location.reload();
      } catch (err) {
        alert(err.message);
      }
    }
  });

  const close = () => {
    dialog.close();
    viewMode.classList.remove('hidden');
    editMode.classList.add('hidden');
    errorEl.classList.add('hidden');
    errorEl.textContent = '';
  };

  closeX.addEventListener('click', close);
  closeBtn.addEventListener('click', close);
  dialog.addEventListener('click', (e) => {
    if (e.target === dialog) close();
  });

  editBtn.addEventListener('click', () => {
    viewMode.classList.add('hidden');
    editMode.classList.remove('hidden');
  });

  cancelEditBtn.addEventListener('click', () => {
    viewMode.classList.remove('hidden');
    editMode.classList.add('hidden');
    errorEl.classList.add('hidden');
  });

  editMode.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(editMode);
    const name = formData.get('name');
    const prompt_paths = formData.getAll('prompts');

    const saveBtn = editMode.querySelector('.save-btn');
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving...';
    errorEl.classList.add('hidden');

    try {
      const res = await fetch(`http://localhost:3001/v1/workflows/${flavor.workflow_name}/flavors/${flavor.flavor_id}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, prompt_paths })
      });

      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.error || 'Failed to update flavor');
      }

      window.location.reload();
    } catch (err) {
      errorEl.textContent = err.message;
      errorEl.classList.remove('hidden');
      saveBtn.disabled = false;
      saveBtn.textContent = 'Save Changes';
    }
  });
</script>

<style>
  .flavor-pill-wrapper {
    display: flex;
    align-items: center;
    gap: 0;
    border: 1px solid var(--btn-border);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.02);
    transition: border-color 0.2s;
  }

  .flavor-pill-wrapper:hover {
    border-color: var(--muted);
  }

  .pill-btn {
    color: var(--body);
    padding: 4px 8px 4px 14px;
    font-size: 13px;
    font-weight: 500;
    background: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .flavor-count {
    background: rgba(255, 255, 255, 0.05);
    color: var(--faint);
    font-size: 10px;
    padding: 2px 6px;
    border-radius: 10px;
    border: 1px solid var(--border-subtle);
  }

  .pill-btn:hover .flavor-count {
    color: var(--muted);
    background: rgba(255, 255, 255, 0.1);
  }

  .delete-flavor-btn {
    color: var(--faint);
    padding: 4px 10px 4px 4px;
    font-size: 10px;
    transition: color 0.2s;
    background: transparent;
    border: none;
    cursor: pointer;
  }

  .delete-flavor-btn:hover {
    color: #f85149;
  }

  .detail-dialog {
    background: transparent;
    border: none;
    padding: 0;
    max-width: 100vw;
    max-height: 100vh;
    margin: auto;
  }

  .detail-dialog::backdrop {
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(4px);
  }

  .modal-content {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 32px;
    width: 700px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .title-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  h2 {
    color: var(--heading);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .edit-btn-inline {
    background: transparent;
    border: none;
    color: var(--muted);
    font-size: 16px;
    cursor: pointer;
    padding: 4px;
    transition: color 0.2s;
  }

  .edit-btn-inline:hover {
    color: var(--heading);
  }

  .close-x {
    color: var(--faint);
    font-size: 18px;
    padding: 4px;
    cursor: pointer;
    background: transparent;
    border: none;
  }

  .close-x:hover {
    color: var(--heading);
  }

  .divider {
    height: 1px;
    background: var(--border-subtle);
    margin-bottom: 24px;
  }

  .modal-error {
    background: rgba(238, 85, 85, 0.1);
    color: #f85149;
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 13px;
    margin-bottom: 24px;
    border: 1px solid rgba(238, 85, 85, 0.2);
  }

  .field {
    margin-bottom: 24px;
  }

  label {
    display: block;
    color: var(--muted);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 10px;
  }

  .path-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .path-list code {
    background: var(--input-bg);
    padding: 4px 10px;
    border-radius: 4px;
    font-size: 13px;
    color: var(--body);
    border: 1px solid var(--border-subtle);
  }

  .preview-box {
    background: #0a0a0a;
    border: 1px solid var(--border);
    border-radius: 8px;
    max-height: 300px;
    overflow-y: auto;
    padding: 16px;
  }

  .preview-text {
    font-family: monospace;
    font-size: 13px;
    color: var(--body);
    white-space: pre-wrap;
    line-height: 1.5;
  }

  .edit-mode input[type="text"] {
    width: 100%;
    padding: 12px 16px;
    background: var(--input-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--body);
    font-size: 15px;
    outline: none;
  }

  .prompt-picker {
    background: var(--input-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    max-height: 240px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }

  .prompt-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    cursor: pointer;
    border-bottom: 1px solid var(--border-subtle);
  }

  .prompt-item:hover {
    background: rgba(255, 255, 255, 0.03);
  }

  .actions {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    margin-top: 32px;
  }

  .close-btn, .cancel-edit-btn, .save-btn {
    padding: 10px 24px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
  }

  .close-btn, .cancel-edit-btn {
    color: var(--muted);
    background: transparent;
    border: none;
  }

  .save-btn {
    background: #d0d0d0;
    color: #000;
    border: 1px solid #d0d0d0;
  }

  .save-btn:hover {
    background: #ffffff;
    border-color: #ffffff;
  }

  .hidden {
    display: none !important;
  }
</style>
