---
import { marked } from 'marked';
import type { GitHubIssueRecord, RepoRecord, ColonyRecord, WorkflowRecord } from '../lib/types';

marked.setOptions({ breaks: true });

export interface IssueWithRepo extends GitHubIssueRecord {
  repo_id: string;
}

interface Props {
  issues: IssueWithRepo[];
  repos: RepoRecord[];
  colonies: ColonyRecord[];
  workflows: WorkflowRecord[];
  showRepoFilter?: boolean;
  repoId?: string;
}

const { issues, repos, colonies, workflows, showRepoFilter = true, repoId } = Astro.props;
---

{showRepoFilter && (
  <div class="repo-filter">
    <label class="form-label" for="repo-select">Repository</label>
    <select class="form-select" id="repo-select">
      <option value="all">All repos</option>
      {repos.map((r) => (
        <option value={r.repo_id}>{r.full_name}</option>
      ))}
    </select>
  </div>
)}

<div class="data-panel" data-repo-id={repoId}>
  <div class="data-panel-header">
    <span class="data-panel-title">Open Issues</span>
    <span class="content-count" id="issue-count">{issues.length}</span>
    {repoId && (
      <button class="btn btn--sm" id="refresh-issues-btn" style="margin-left: auto;">Refresh</button>
    )}
  </div>
  <div class="data-panel-body">
    {issues.length === 0 ? (
      <div class="empty-state">
        <div class="empty-state-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <div class="empty-state-title">No open issues</div>
        <p class="empty-state-desc">All GitHub issues are resolved.</p>
      </div>
    ) : (
      <div class="issue-list" id="issue-list">
        {issues.map((issue) => {
          const repo = repos.find((r) => r.repo_id === issue.repo_id);
          return (
            <div class="issue-card" data-issue-number={issue.number} data-repo-id={issue.repo_id}>
              <div class="issue-card-header">
                <div class="issue-card-title">
                  <span class="issue-number">#{issue.number}</span>
                  {issue.title}
                </div>
                {issue.already_queued ? (
                  <span class="badge badge--muted">Queued</span>
                ) : (
                  <button
                    class="btn btn--primary btn--sm launch-mission-btn"
                    data-issue-number={issue.number}
                    data-issue-title={issue.title}
                    data-repo-id={issue.repo_id}
                    data-repo-name={repo?.full_name}
                  >
                    Create Mission
                  </button>
                )}
              </div>
              <div class="issue-card-body issue-prose" set:html={marked.parse(issue.body || '')} />
              <div class="issue-card-footer">
                {repo && (
                  <span>{repo.full_name}</span>
                )}
                {issue.labels.map((label) => (
                  <span class="issue-label">{label}</span>
                ))}
                <span class={`issue-state issue-state--${issue.state}`}>{issue.state}</span>
              </div>
            </div>
          );
        })}
      </div>
    )}
  </div>
</div>

<!-- Mission Launch Modal -->
<dialog class="modal" id="launch-modal">
  <div class="modal-content">
    <div class="modal-header">
      <span class="modal-title">Create Mission</span>
      <button class="modal-close" id="launch-modal-close">&times;</button>
    </div>
    <div class="modal-body">
      <div class="launch-issue-ref" id="launch-issue-ref"></div>
      <div class="launch-repo-ref" id="launch-repo-ref"></div>

      <div class="form-group">
        <label class="form-label" for="launch-colony">Colony</label>
        <select class="form-select" id="launch-colony">
          {colonies.map((c) => (
            <option value={c.colony_id}>{c.name}</option>
          ))}
          <option value="__new__">Create new&hellip;</option>
        </select>
      </div>

      <div class="form-group" id="launch-new-colony-group" hidden>
        <label class="form-label" for="launch-new-colony-name">New colony name</label>
        <input type="text" class="form-input" id="launch-new-colony-name" placeholder="my-colony" />
      </div>

      <div class="form-group">
        <label class="form-label" for="launch-workflow">Workflow (optional)</label>
        <select class="form-select" id="launch-workflow">
          <option value="">None</option>
          {workflows.map((wf) => (
            <option value={wf.name}>{wf.name}</option>
          ))}
        </select>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn" id="launch-cancel">Cancel</button>
      <button class="btn btn--primary" id="launch-execute">Create</button>
    </div>
  </div>
</dialog>

<script>
  import { marked } from 'marked';
  marked.setOptions({ breaks: true });

  const modal = document.getElementById('launch-modal') as HTMLDialogElement;
  const issueRef = document.getElementById('launch-issue-ref')!;
  const repoRef = document.getElementById('launch-repo-ref')!;
  const closeBtn = document.getElementById('launch-modal-close')!;
  const cancelBtn = document.getElementById('launch-cancel')!;
  const executeBtn = document.getElementById('launch-execute') as HTMLButtonElement;
  const repoSelect = document.getElementById('repo-select') as HTMLSelectElement | null;
  const issueList = document.getElementById('issue-list')!;
  const issueCount = document.getElementById('issue-count')!;
  const refreshBtn = document.getElementById('refresh-issues-btn') as HTMLButtonElement | null;
  const dataPanel = document.querySelector<HTMLElement>('.data-panel[data-repo-id]');
  const colonySelect = document.getElementById('launch-colony') as HTMLSelectElement;
  const newColonyGroup = document.getElementById('launch-new-colony-group')!;
  const newColonyInput = document.getElementById('launch-new-colony-name') as HTMLInputElement;
  const workflowSelect = document.getElementById('launch-workflow') as HTMLSelectElement;

  let currentIssueNumber: number | null = null;
  let currentRepoId: string | null = null;

  colonySelect.addEventListener('change', () => {
    newColonyGroup.hidden = colonySelect.value !== '__new__';
  });

  // Repo filter
  repoSelect?.addEventListener('change', () => {
    const val = repoSelect.value;
    let visible = 0;
    issueList.querySelectorAll<HTMLElement>('.issue-card').forEach((card) => {
      const show = val === 'all' || card.dataset.repoId === val;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    issueCount.textContent = String(visible);
  });

  // Refresh issues
  refreshBtn?.addEventListener('click', async () => {
    const repoId = dataPanel?.dataset.repoId;
    if (!repoId) return;

    refreshBtn.textContent = 'Refreshing...';
    refreshBtn.disabled = true;

    try {
      const res = await fetch(`/api/repos/${repoId}/issues`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const issues: Array<{
        number: number;
        title: string;
        body: string;
        labels: string[];
        state: string;
        already_queued: boolean;
      }> = await res.json();

      issueList.innerHTML = issues.map((issue) => `
        <div class="issue-card" data-issue-number="${issue.number}" data-repo-id="${repoId}">
          <div class="issue-card-header">
            <div class="issue-card-title">
              <span class="issue-number">#${issue.number}</span>
              ${issue.title}
            </div>
            ${issue.already_queued
              ? '<span class="badge badge--muted">Queued</span>'
              : `<button class="btn btn--primary btn--sm launch-mission-btn"
                  data-issue-number="${issue.number}"
                  data-issue-title="${issue.title.replace(/"/g, '&quot;')}"
                  data-repo-id="${repoId}"
                >Create Mission</button>`}
          </div>
          <div class="issue-card-body issue-prose">${marked.parse(issue.body || '')}</div>
          <div class="issue-card-footer">
            ${issue.labels.map((l) => `<span class="issue-label">${l}</span>`).join('')}
            <span class="issue-state issue-state--${issue.state}">${issue.state}</span>
          </div>
        </div>
      `).join('');

      issueCount.textContent = String(issues.length);
      bindLaunchButtons();
    } catch (e) {
      console.error('Failed to refresh issues:', e);
    } finally {
      refreshBtn.textContent = 'Refresh';
      refreshBtn.disabled = false;
    }
  });

  // Launch modal
  function resetModal() {
    colonySelect.selectedIndex = 0;
    newColonyGroup.hidden = true;
    newColonyInput.value = '';
    workflowSelect.selectedIndex = 0;
    executeBtn.textContent = 'Create';
    executeBtn.disabled = false;
    currentIssueNumber = null;
    currentRepoId = null;
  }

  function bindLaunchButtons() {
    document.querySelectorAll<HTMLButtonElement>('.launch-mission-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        resetModal();
        currentIssueNumber = Number(btn.dataset.issueNumber);
        currentRepoId = btn.dataset.repoId || null;
        const title = btn.dataset.issueTitle;
        const repoName = btn.dataset.repoName;
        issueRef.textContent = `#${currentIssueNumber} — ${title}`;
        repoRef.textContent = repoName || '';
        modal.showModal();
      });
    });
  }
  bindLaunchButtons();

  closeBtn.addEventListener('click', () => { modal.close(); resetModal(); });
  cancelBtn.addEventListener('click', () => { modal.close(); resetModal(); });
  modal.addEventListener('click', (e) => {
    if (e.target === modal) { modal.close(); resetModal(); }
  });

  executeBtn.addEventListener('click', async () => {
    if (!currentIssueNumber) return;

    executeBtn.textContent = 'Creating...';
    executeBtn.disabled = true;

    try {
      let colonyId = colonySelect.value;

      // Create colony if needed
      if (colonyId === '__new__') {
        const name = newColonyInput.value.trim();
        if (!name) {
          alert('Colony name is required.');
          executeBtn.textContent = 'Create';
          executeBtn.disabled = false;
          return;
        }
        const colonyRes = await fetch('/api/colonies', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name }),
        });
        if (!colonyRes.ok) {
          const err = await colonyRes.json().catch(() => ({ error: 'Unknown error' }));
          throw new Error(err.error || `Failed to create colony: ${colonyRes.status}`);
        }
        const colony = await colonyRes.json();
        colonyId = colony.colony_id;
      }

      // Queue the issue as a mission
      const body: Record<string, unknown> = { issue_number: currentIssueNumber };
      const workflow = workflowSelect.value;
      if (workflow) body.workflow = workflow;

      const res = await fetch(`/api/colonies/${colonyId}/queue`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: 'Unknown error' }));
        throw new Error(err.error || `Failed to queue issue: ${res.status}`);
      }

      modal.close();
      resetModal();
      window.location.reload();
    } catch (e: unknown) {
      executeBtn.textContent = 'Create';
      executeBtn.disabled = false;
      alert(`Error: ${e instanceof Error ? e.message : e}`);
    }
  });
</script>
