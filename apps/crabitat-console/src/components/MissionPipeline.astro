---
import type { MissionRecord, TaskRecord, RepoRecord } from '../lib/types';
import { timeAgo } from '../lib/format';
import StepPipeline from './StepPipeline.astro';
import type { PipelineStep } from './StepPipeline.astro';

interface Props {
  missions: MissionRecord[];
  tasks: TaskRecord[];
  repos: RepoRecord[];
}

const { missions, tasks, repos } = Astro.props;

function truncate(text: string, max: number): string {
  if (text.length <= max) return text;
  return text.slice(0, max) + '\u2026';
}

function repoName(repoId: string): string {
  const repo = repos.find((r) => r.repo_id === repoId);
  return repo?.full_name || repoId.slice(0, 8);
}

function tasksForMission(missionId: string): TaskRecord[] {
  return tasks
    .filter((t) => t.mission_id === missionId)
    .sort((a, b) => a.created_at_ms - b.created_at_ms);
}

function tasksToSteps(mTasks: TaskRecord[]): PipelineStep[] {
  return mTasks.map((task, i) => ({
    label: task.step_id || task.title,
    position: i,
    status: task.status,
  }));
}
---

<div class="data-panel">
  <div class="data-panel-header">
    <span class="data-panel-title">Missions</span>
    <span class="content-count">{missions.length}</span>
  </div>
  <div class="data-panel-body">
    {missions.length === 0 ? (
      <div class="empty-state">
        <div class="empty-state-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
        </div>
        <div class="empty-state-title">No missions yet</div>
        <p class="empty-state-desc">Create one to get started.</p>
      </div>
    ) : (
      <div class="mission-list">
        {missions.map((mission) => {
          const mTasks = tasksForMission(mission.mission_id);
          return (
            <div class="mission-card" data-mission-id={mission.mission_id}>
              <div class="mission-card-header">
                <div class="mission-card-title">
                  <span class={`badge badge--${mission.status}`}>{mission.status}</span>
                  <span class="mission-title-text">{truncate(mission.prompt, 80)}</span>
                </div>
                <div class="mission-card-meta">
                  <span>{repoName(mission.repo_id)}</span>
                  {mission.workflow_name && (
                    <code class="branch-name">{mission.workflow_name}</code>
                  )}
                  {mission.github_issue_number && (
                    <span class="issue-number">#{mission.github_issue_number}</span>
                  )}
                  {mission.github_pr_number && (
                    <span class="pr-ref">PR #{mission.github_pr_number}</span>
                  )}
                  <span class="mission-time">{timeAgo(mission.created_at_ms)}</span>
                </div>
              </div>

              {mTasks.length > 0 && (
                <StepPipeline steps={tasksToSteps(mTasks)} />
              )}
            </div>
          );
        })}
      </div>
    )}
  </div>
</div>
