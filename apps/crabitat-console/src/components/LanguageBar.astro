---
interface Props {
  repoId: string;
}

const { repoId } = Astro.props;
---

<div class="language-bar-container" data-repo-id={repoId}>
  <div class="language-bar-loading">Detecting languages...</div>
</div>

<script>
  const containers = document.querySelectorAll('.language-bar-container[data-repo-id]');

  const LANG_COLORS: Record<string, string> = {
    'Rust': '#dea584',
    'TypeScript': '#3178c6',
    'JavaScript': '#f1e05a',
    'Astro': '#ff5a03',
    'Python': '#3572A5',
    'Go': '#00ADD8',
    'Java': '#b07219',
    'Ruby': '#701516',
    'C': '#555555',
    'C++': '#f34b7d',
    'Swift': '#F05138',
    'Kotlin': '#A97BFF',
    'Shell': '#89e051',
    'HTML': '#e34c26',
    'CSS': '#563d7c',
    'SCSS': '#c6538c',
    'TOML': '#9c4221',
    'YAML': '#cb171e',
    'JSON': '#292929',
    'Markdown': '#083fa1',
    'SQL': '#e38c00',
    'SVG': '#ff9900',
    'Zig': '#ec915c',
    'Nix': '#7e7eff',
    'Lua': '#000080',
  };

  function getColor(lang: string): string {
    return LANG_COLORS[lang] || '#8b8b8b';
  }

  containers.forEach(async (container) => {
    const repoId = (container as HTMLElement).dataset.repoId!;

    try {
      const res = await fetch(`/api/repos/${repoId}/languages`);
      if (!res.ok) throw new Error(`${res.status}`);
      const data: Record<string, number> = await res.json();

      const entries = Object.entries(data).sort((a, b) => b[1] - a[1]);
      if (entries.length === 0) {
        container.innerHTML = '<div class="language-bar-empty">No languages detected</div>';
        return;
      }

      const total = entries.reduce((sum, [, bytes]) => sum + bytes, 0);

      const barHtml = entries
        .map(([lang, bytes]) => {
          const pct = ((bytes / total) * 100).toFixed(1);
          return `<div class="lang-segment" style="width: ${pct}%; background: ${getColor(lang)}" title="${lang} ${pct}%"></div>`;
        })
        .join('');

      const legendHtml = entries
        .map(([lang, bytes]) => {
          const pct = ((bytes / total) * 100).toFixed(1);
          return `<span class="lang-legend-item"><span class="lang-dot" style="background: ${getColor(lang)}"></span>${lang} <span class="lang-pct">${pct}%</span></span>`;
        })
        .join('');

      container.innerHTML = `<div class="language-bar">${barHtml}</div><div class="lang-legend">${legendHtml}</div>`;
    } catch {
      container.innerHTML = '<div class="language-bar-empty">Failed to detect languages</div>';
    }
  });
</script>

<style>
  .language-bar-container {
    margin-top: 12px;
  }

  .language-bar-loading,
  .language-bar-empty {
    font-size: 12px;
    color: var(--muted);
    padding: 4px 0;
  }

  .language-bar {
    display: flex;
    height: 10px;
    border-radius: 5px;
    overflow: hidden;
    background: var(--neutral-bg);
  }

  :global(.lang-segment) {
    height: 100%;
    min-width: 2px;
    transition: opacity 0.15s;
  }

  :global(.lang-segment:hover) {
    opacity: 0.75;
  }

  :global(.lang-legend) {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 8px;
  }

  :global(.lang-legend-item) {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 12px;
    color: var(--ink);
  }

  :global(.lang-dot) {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  :global(.lang-pct) {
    color: var(--muted);
    font-size: 11px;
  }
</style>
