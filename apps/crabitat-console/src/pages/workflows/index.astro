---
import Layout from "../../layouts/Layout.astro";
import WorkflowCard from "../../components/WorkflowCard.astro";
import NewWorkflowModal from "../../components/NewWorkflowModal.astro";
import { listAllWorkflows, getWorkflow, listRepos } from "../../lib/api-client";
import type { WorkflowSummary, WorkflowDetail, Repo } from "../../lib/types";

let summaries: WorkflowSummary[] = [];
let details: Map<string, WorkflowDetail> = new Map();
let repos: Repo[] = [];
let error = "";

try {
  [summaries, repos] = await Promise.all([listAllWorkflows(), listRepos()]);
  const detailResults = await Promise.all(
    summaries.map((s) => getWorkflow(s.workflow_id)),
  );
  for (const d of detailResults) {
    details.set(d.workflow_id, d);
  }
} catch (e) {
  error = e instanceof Error ? e.message : String(e);
}
---

<Layout title="Workflows">
  <div class="page-header">
    <div>
      <h1>Workflows</h1>
      <p class="subtitle">Repo-scoped templates with ordered steps and flavors</p>
    </div>
    <NewWorkflowModal repos={repos} />
  </div>

  <div class="divider"></div>

  {error && <p class="error">{error}</p>}

  {summaries.length === 0 && !error && (
    <div class="empty">
      <p>No workflows created yet.</p>
      <p>Click <strong>+ New Workflow</strong> to get started.</p>
    </div>
  )}

  <div class="grid">
    {summaries.map((s) => {
      const d = details.get(s.workflow_id);
      return d ? <WorkflowCard summary={s} detail={d} /> : null;
    })}
  </div>
</Layout>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  h1 {
    color: var(--heading);
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .subtitle {
    color: #777;
    font-size: 13px;
    margin-top: 4px;
  }

  .divider {
    height: 1px;
    background: var(--border-subtle);
    margin: 20px 0;
  }

  .error {
    color: #e55;
    padding: 12px;
    background: rgba(238, 85, 85, 0.1);
    border-radius: 6px;
    font-size: 13px;
    margin-bottom: 20px;
  }

  .empty {
    text-align: center;
    padding: 60px 20px;
    color: var(--muted);
    font-size: 14px;
  }

  .empty strong {
    color: var(--body);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
    gap: 24px;
  }
</style>
