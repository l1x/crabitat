---
import Layout from "../../layouts/Layout.astro";
import WorkflowCard from "../../components/WorkflowCard.astro";
import { listAllWorkflows, getWorkflow } from "../../lib/api-client";
import type { WorkflowSummary, WorkflowDetail } from "../../lib/types";

let summaries: WorkflowSummary[] = [];
let details: Map<string, WorkflowDetail> = new Map();
let error = "";
let needsConfig = false;

try {
  summaries = await listAllWorkflows();
  const detailResults = await Promise.all(
    summaries.map((s) => getWorkflow(s.name)),
  );
  for (const d of detailResults) {
    details.set(d.name, d);
  }
} catch (e) {
  if (e instanceof Error && e.message.includes("424")) {
    needsConfig = true;
  } else {
    error = e instanceof Error ? e.message : String(e);
  }
}
---

<Layout title="Workflows">
  <div class="page-header">
    <div>
      <h1>Workflows</h1>
      <p class="subtitle">Global templates from your prompts repository</p>
    </div>
  </div>

  <div class="divider"></div>

  {error && <p class="message error">{error}</p>}

  {needsConfig && (
    <div class="empty-state">
      <div class="icon">⚙️</div>
      <h2>Configuration Required</h2>
      <p>You need to configure your <strong>Prompts Root Path</strong> before workflows can be loaded.</p>
      <a href="/settings" class="primary-btn">Go to Settings</a>
    </div>
  )}

  {!needsConfig && summaries.length === 0 && !error && (
    <div class="empty-state">
      <div class="icon">📂</div>
      <h2>No Workflows Found</h2>
      <p>No <code>.toml</code> files found in your <code>workflows/</code> directory.</p>
      <p class="hint">Check your settings or add workflows to your prompts repo.</p>
    </div>
  )}

  <div class="grid">
    {summaries.map((s) => {
      const d = details.get(s.name);
      return d ? <WorkflowCard summary={s} detail={d} /> : null;
    })}
  </div>
</Layout>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  h1 {
    color: var(--heading);
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .subtitle {
    color: var(--muted);
    font-size: 13px;
    margin-top: 4px;
  }

  .divider {
    height: 1px;
    background: var(--border-subtle);
    margin: 20px 0 40px;
  }

  .message {
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 13px;
    margin-bottom: 24px;
  }

  .error {
    background: var(--status-error-bg);
    color: var(--status-error);
    border: 1px solid var(--status-error-border);
  }

  .empty-state {
    text-align: center;
    padding: 80px 40px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    max-width: 600px;
    margin: 40px auto;
    box-shadow: 0 10px 30px var(--shadow-elevated);
  }

  .empty-state .icon {
    font-size: 48px;
    margin-bottom: 24px;
  }

  .empty-state h2 {
    color: var(--heading);
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .empty-state p {
    color: var(--muted);
    font-size: 16px;
    margin-bottom: 32px;
    line-height: 1.6;
  }

  .hint {
    font-size: 14px !important;
    opacity: 0.7;
  }

  .primary-btn {
    display: inline-block;
    background: var(--primary-bg);
    color: var(--primary-text);
    text-decoration: none;
    padding: 12px 32px;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 600;
    transition: all 0.2s;
    border: 1px solid var(--primary-bg);
  }

  .primary-btn:hover {
    background: var(--primary-hover);
    border-color: var(--primary-hover);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
    gap: 24px;
  }
</style>
