---
import Layout from "../../layouts/Layout.astro";
import RepoCard from "../../components/RepoCard.astro";
import AddRepoModal from "../../components/AddRepoModal.astro";
import { listRepos } from "../../lib/api-client";
import type { Repo } from "../../lib/types";

let repos: Repo[] = [];
let error = "";

try {
  repos = await listRepos();
} catch (e) {
  error = e instanceof Error ? e.message : String(e);
}
---

<Layout title="Repositories">
  <div class="page-header">
    <div>
      <h1>Repositories</h1>
      <p class="subtitle">Onboarded GitHub repos managed by Crabitat</p>
    </div>
    <AddRepoModal />
  </div>

  <div class="divider"></div>

  {error && <p class="error">{error}</p>}

  {repos.length === 0 && !error && (
    <div class="empty">
      <p>No repositories onboarded yet.</p>
      <p>Click <strong>+ Add Repo</strong> to get started.</p>
    </div>
  )}

  <div class="grid">
    {repos.map((repo) => <RepoCard repo={repo} />)}
  </div>
</Layout>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  h1 {
    color: var(--heading);
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .subtitle {
    color: var(--muted);
    font-size: 13px;
    margin-top: 4px;
  }

  .divider {
    height: 1px;
    background: var(--border-subtle);
    margin: 20px 0;
  }

  .error {
    color: #e55;
    padding: 12px;
    background: rgba(238, 85, 85, 0.1);
    border-radius: 6px;
    font-size: 13px;
    margin-bottom: 20px;
  }

  .empty {
    text-align: center;
    padding: 60px 20px;
    color: var(--muted);
    font-size: 14px;
  }

  .empty strong {
    color: var(--body);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 280px));
    gap: 24px;
  }
</style>
