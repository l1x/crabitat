---
import Layout from '../../../layouts/Layout.astro';
import Sidebar from '../../../components/Sidebar.astro';
import ContentHeader from '../../../components/ContentHeader.astro';
import IssueList from '../../../components/IssueList.astro';
import WorkflowList from '../../../components/WorkflowList.astro';
import MissionPipeline from '../../../components/MissionPipeline.astro';
import LanguageBar from '../../../components/LanguageBar.astro';
import { fetchStatus, fetchRepoIssues, fetchWorkflows, fetchTasks } from '../../../lib/api-client';
import type { IssueWithRepo } from '../../../components/IssueList.astro';
import type { StatusSnapshot, GitHubIssueRecord, WorkflowRecord, TaskRecord } from '../../../lib/types';

let status: StatusSnapshot | null = null;
try { status = await fetchStatus(); } catch {}

const repos = status?.repos ?? [];
const missions = status?.missions ?? [];
const crabs = status?.crabs ?? [];

const { owner, name } = Astro.params;
const repo = repos.find((r) => r.owner === owner && r.name === name);

if (!repo) {
  return Astro.redirect('/repos');
}

let repoIssuesRaw: GitHubIssueRecord[] = [];
try { repoIssuesRaw = await fetchRepoIssues(repo.repo_id); } catch {}
const repoIssues: IssueWithRepo[] = repoIssuesRaw.map((i) => ({ ...i, repo_id: repo.repo_id }));

let workflows: WorkflowRecord[] = [];
try { workflows = await fetchWorkflows(); } catch {}

let tasks: TaskRecord[] = [];
try { tasks = await fetchTasks(); } catch {}

const repoMissions = missions.filter((m) => m.repo_id === repo.repo_id);
---

<Layout title={`${repo.full_name} — Crabitat Console`}>
  <Sidebar
    activePage="/repos"
    repoCount={repos.length}
    issueCount={repoIssues.length}
    missionCount={missions.length}
    agentCount={crabs.length}
    messageCount={0}
    workflowCount={workflows.length}
  />

  <div class="content">
    <ContentHeader title={repo.full_name} />

    <div class="section">
      <a href="/repos" class="repo-detail-back">&larr; All repos</a>

      <div class="repo-detail-header">
        <div class="repo-detail-info">
          <code class="branch-name">{repo.default_branch}</code>
          {repo.language && <span>{repo.language}</span>}
        </div>
        <div class="repo-detail-path">
          <code>{repo.local_path}</code>
        </div>
      </div>

      <div class="repo-stacks-section" id="repo-stacks-section" data-repo-id={repo.repo_id}>
        <div class="repo-stacks-header">
          <span class="repo-stacks-label">Stacks</span>
          <button class="btn btn--sm" id="edit-stacks-btn">Edit</button>
        </div>
        <div class="repo-stacks-pills" id="repo-stacks-pills">
          {(repo.stacks && repo.stacks.length > 0) ? (
            repo.stacks.map((s) => <span class="stack-pill">{s}</span>)
          ) : (
            <span class="repo-stacks-none">No stacks configured</span>
          )}
        </div>
        <div class="repo-stacks-editor" id="repo-stacks-editor" hidden>
          <div class="stacks-picker" id="repo-stacks-picker">Loading...</div>
          <div class="repo-stacks-editor-actions">
            <button class="btn btn--sm" id="stacks-editor-cancel">Cancel</button>
            <button class="btn btn--sm btn--primary" id="stacks-editor-save">Save</button>
          </div>
        </div>
      </div>

      <LanguageBar repoId={repo.repo_id} />

      <IssueList issues={repoIssues} repos={[repo]} workflows={workflows} showRepoFilter={false} repoId={repo.repo_id} />

      <WorkflowList workflows={workflows} />

      <MissionPipeline missions={repoMissions} tasks={tasks} repos={[repo]} />
    </div>
  </div>
</Layout>

<script>
  const section = document.getElementById('repo-stacks-section')!;
  const repoId = section.dataset.repoId!;
  const pillsDiv = document.getElementById('repo-stacks-pills')!;
  const editorDiv = document.getElementById('repo-stacks-editor')!;
  const pickerDiv = document.getElementById('repo-stacks-picker')!;
  const editBtn = document.getElementById('edit-stacks-btn')!;
  const cancelBtn = document.getElementById('stacks-editor-cancel')!;
  const saveBtn = document.getElementById('stacks-editor-save')!;

  interface StackEntry { name: string; path: string; }

  let availableStacks: StackEntry[] = [];
  let currentStacks: string[] = [];

  // Parse current stacks from pills
  pillsDiv.querySelectorAll<HTMLElement>('.stack-pill').forEach((el) => {
    currentStacks.push(el.textContent!.trim());
  });

  async function loadStacks() {
    try {
      const res = await fetch('/api/stacks');
      if (!res.ok) throw new Error(`${res.status}`);
      availableStacks = await res.json();
      renderEditor();
    } catch {
      pickerDiv.textContent = 'Failed to load stacks';
    }
  }

  function renderEditor() {
    if (availableStacks.length === 0) {
      pickerDiv.textContent = 'No stacks discovered';
      return;
    }
    pickerDiv.innerHTML = availableStacks
      .map(
        (s) => `
        <label class="stack-chip">
          <input type="checkbox" class="stack-checkbox" value="${s.name}" ${currentStacks.includes(s.name) ? 'checked' : ''} />
          <span class="stack-chip-label">${s.name}</span>
        </label>
      `
      )
      .join('');
  }

  editBtn.addEventListener('click', () => {
    editorDiv.hidden = false;
    editBtn.hidden = true;
    loadStacks();
  });

  cancelBtn.addEventListener('click', () => {
    editorDiv.hidden = true;
    editBtn.hidden = false;
  });

  saveBtn.addEventListener('click', async () => {
    const selected = Array.from(
      pickerDiv.querySelectorAll<HTMLInputElement>('.stack-checkbox:checked')
    ).map((cb) => cb.value);

    saveBtn.textContent = 'Saving...';
    saveBtn.setAttribute('disabled', '');

    try {
      const res = await fetch(`/api/repos/${repoId}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ stacks: selected }),
      });
      if (!res.ok) throw new Error(`${res.status}`);

      currentStacks = selected;
      pillsDiv.innerHTML = selected.length > 0
        ? selected.map((s) => `<span class="stack-pill">${s}</span>`).join('')
        : '<span class="repo-stacks-none">No stacks configured</span>';

      editorDiv.hidden = true;
      editBtn.hidden = false;
    } catch (e) {
      alert(`Failed to save stacks: ${e instanceof Error ? e.message : e}`);
    } finally {
      saveBtn.textContent = 'Save';
      saveBtn.removeAttribute('disabled');
    }
  });
</script>

<style>
  .repo-stacks-section {
    margin: 16px 0;
    padding: 12px 16px;
    background: var(--panel, #fff);
    border: 1px solid var(--line, #e5e7eb);
    border-radius: 10px;
  }

  .repo-stacks-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .repo-stacks-label {
    font-weight: 600;
    font-size: 13px;
    color: var(--ink, #1a1d26);
  }

  .repo-stacks-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .stack-pill {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 999px;
    background: var(--primary-soft, #eef0ff);
    color: var(--primary, #5b6abf);
    font-size: 12px;
    font-weight: 600;
    font-family: var(--font-mono, monospace);
  }

  .repo-stacks-none {
    font-size: 13px;
    color: var(--muted, #6b7280);
  }

  .repo-stacks-editor {
    margin-top: 10px;
  }

  .stacks-picker {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 4px 0;
  }

  .stack-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border: 1px solid var(--line, #e2e5ed);
    border-radius: 999px;
    cursor: pointer;
    font-size: 13px;
    transition: border-color 0.15s, background 0.15s;
    user-select: none;
  }

  .stack-chip:hover {
    border-color: var(--primary, #5b6abf);
    background: var(--primary-soft, #eef0ff);
  }

  .stack-chip:has(.stack-checkbox:checked) {
    border-color: var(--primary, #5b6abf);
    background: var(--primary-soft, #eef0ff);
    color: var(--primary, #5b6abf);
    font-weight: 600;
  }

  .stack-checkbox {
    width: 14px;
    height: 14px;
    accent-color: var(--primary, #5b6abf);
  }

  .stack-chip-label {
    font-family: var(--font-mono, monospace);
  }

  .repo-stacks-editor-actions {
    display: flex;
    gap: 8px;
    margin-top: 10px;
  }
</style>
