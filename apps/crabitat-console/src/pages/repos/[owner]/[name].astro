---
import Layout from '../../../layouts/Layout.astro';
import Sidebar from '../../../components/Sidebar.astro';
import ContentHeader from '../../../components/ContentHeader.astro';
import IssueList from '../../../components/IssueList.astro';
import WorkflowList from '../../../components/WorkflowList.astro';
import MissionPipeline from '../../../components/MissionPipeline.astro';
import LanguageBar from '../../../components/LanguageBar.astro';
import { fetchRepos, fetchRepoIssues, fetchWorkflows, fetchRoles, fetchPromptFiles } from '../../../lib/api-client';
import { mockIssues, mockMissions, mockAgents, mockMessages, getMissionsForRepo } from '../../../lib/mock-data';
import type { RepoRecord, GitHubIssueRecord, WorkflowRecord } from '../../../lib/types';

let repos: RepoRecord[] = [];
try { repos = await fetchRepos(); } catch {}

const { owner, name } = Astro.params;
const repo = repos.find((r) => r.owner === owner && r.name === name);

if (!repo) {
  return Astro.redirect('/repos');
}

let repoIssues: GitHubIssueRecord[] = [];
try { repoIssues = await fetchRepoIssues(repo.repo_id); } catch {}

let workflows: WorkflowRecord[] = [];
try { workflows = await fetchWorkflows(); } catch {}

let roles = [];
try { roles = await fetchRoles(); } catch {}

let promptFiles: string[] = [];
try { promptFiles = await fetchPromptFiles(); } catch {}

const repoMissions = getMissionsForRepo(repo.repo_id);
---

<Layout title={`${repo.full_name} — Crabitat Console`}>
  <Sidebar
    activePage="/repos"
    repoCount={repos.length}
    issueCount={mockIssues.length}
    missionCount={mockMissions.length}
    agentCount={mockAgents.length}
    messageCount={mockMessages.length}
    workflowCount={workflows.length}
    promptCount={promptFiles.length}
    roleCount={roles.length}
  />

  <div class="content">
    <ContentHeader title={repo.full_name} />

    <div class="section">
      <a href="/repos" class="repo-detail-back">&larr; All repos</a>

      <div class="repo-detail-header">
        <div class="repo-detail-info">
          <code class="branch-name">{repo.default_branch}</code>
          {repo.language && <span>{repo.language}</span>}
        </div>
        <div class="repo-detail-path">
          <code>{repo.local_path}</code>
        </div>
      </div>

      <LanguageBar repoId={repo.repo_id} />

      <IssueList issues={repoIssues} repos={[repo]} showRepoFilter={false} repoId={repo.repo_id} />

      <WorkflowList workflows={workflows} />

      <MissionPipeline missions={repoMissions} repos={[repo]} />
    </div>
  </div>
</Layout>
