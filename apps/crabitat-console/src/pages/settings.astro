---
import Layout from "../layouts/Layout.astro";
import { listSettings, listEnvironmentPaths } from "../lib/api-client";
import type { Setting, EnvironmentPath } from "../lib/types";

let settings: Setting[] = [];
let envPaths: EnvironmentPath[] = [];
let error = "";
let success = "";

try {
  settings = await listSettings();
  envPaths = await listEnvironmentPaths();
} catch (e) {
  error = e instanceof Error ? e.message : String(e);
}
---

<Layout title="Settings">
  <div class="page-header">
    <div>
      <h1>Settings</h1>
      <p class="subtitle">Global system configuration</p>
    </div>
  </div>

  <div class="divider"></div>

  {error && <p class="message error">{error}</p>}
  {success && <p class="message success">{success}</p>}

  <div class="settings-container">
    <div class="setting-group">
      <h3>Agent Prompts</h3>
      <p class="description">
        Point Crabitat to your prompts repository or local directory containing <code>workflows/</code> and <code>prompts/</code>.
      </p>
      
      <div class="input-row">
        <label for="prompts_root">Prompts Root Path</label>
        <div class="input-group">
          <input 
            type="text" 
            id="prompts_root" 
            name="prompts_root" 
            value={settings.find(s => s.key === 'prompts_root')?.value || ''}
            placeholder="/path/to/your/agent-prompts"
          />
          <button id="save-prompts-root" class="primary-btn">Save</button>
        </div>
      </div>
    </div>

    <div class="setting-group">
      <h3>Environment Paths</h3>
      <p class="description">
        Absolute paths for agents and repositories across different environments.
      </p>
      
      <div class="table-container">
        <table class="env-table">
          <thead>
            <tr>
              <th>Environment</th>
              <th>Type</th>
              <th>Resource</th>
              <th>Path</th>
            </tr>
          </thead>
          <tbody>
            {envPaths.map(p => (
              <tr>
                <td class="pill-cell"><span class={`pill ${p.environment}`}>{p.environment}</span></td>
                <td class="type-cell">{p.resource_type}</td>
                <td class="name-cell">{p.resource_name}</td>
                <td class="path-cell"><code>{p.path}</code></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { updateSetting } from "../lib/api-client";

  const saveBtn = document.getElementById('save-prompts-root');
  const input = document.getElementById('prompts_root') as HTMLInputElement;

  saveBtn?.addEventListener('click', async () => {
    const value = input.value.trim();
    if (!value) return;

    saveBtn.innerText = 'Saving...';
    saveBtn.setAttribute('disabled', 'true');

    try {
      await updateSetting('prompts_root', value);
      window.location.reload();
    } catch (e) {
      alert(e instanceof Error ? e.message : String(e));
      saveBtn.innerText = 'Save';
      saveBtn.removeAttribute('disabled');
    }
  });
</script>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  h1 {
    color: var(--heading);
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .subtitle {
    color: var(--muted);
    font-size: 13px;
    margin-top: 4px;
  }

  .divider {
    height: 1px;
    background: var(--border-subtle);
    margin: 20px 0 32px;
  }

  .settings-container {
    max-width: 800px;
  }

  .setting-group {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 32px;
    margin-bottom: 24px;
    box-shadow: 0 4px 20px var(--shadow-card);
  }

  .setting-group h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--heading);
  }

  .description {
    font-size: 15px;
    color: var(--muted);
    margin-bottom: 24px;
    line-height: 1.6;
  }

  .input-row {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  label {
    font-size: 12px;
    font-weight: 700;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .input-group {
    display: flex;
    gap: 12px;
  }

  input {
    flex-grow: 1;
    background: var(--input-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px 16px;
    color: var(--body);
    font-size: 15px;
    font-family: monospace;
    transition: border-color 0.2s;
    outline: none;
  }

  input:focus {
    border-color: var(--muted);
  }

  .primary-btn {
    background: var(--primary-bg);
    color: var(--primary-text);
    border: 1px solid var(--primary-bg);
    border-radius: 8px;
    padding: 0 32px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .primary-btn:hover {
    background: var(--primary-hover);
    border-color: var(--primary-hover);
  }

  .primary-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .message {
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 13px;
    margin-bottom: 24px;
  }

  .error {
    background: var(--status-error-bg);
    color: var(--status-error);
    border: 1px solid var(--status-error-border);
  }

  .success {
    background: var(--status-success-bg);
    color: var(--status-success);
    border: 1px solid var(--status-success-border);
  }

  .table-container {
    overflow-x: auto;
  }

  .env-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }

  .env-table th {
    text-align: left;
    color: var(--muted);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
  }

  .env-table td {
    padding: 12px 16px;
    border-bottom: 1px solid var(--border-subtle);
    color: var(--body);
  }

  .pill {
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .pill.local {
    background: var(--env-local-bg);
    color: var(--env-local-text);
  }

  .pill.remote {
    background: var(--env-remote-bg);
    color: var(--env-remote-text);
  }

  .path-cell code {
    background: var(--input-bg);
    padding: 4px 8px;
    border-radius: 4px;
    font-family: monospace;
    font-size: 13px;
  }
</style>
