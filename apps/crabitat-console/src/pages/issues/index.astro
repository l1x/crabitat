---
import Layout from "../../layouts/Layout.astro";
import { listRepos } from "../../lib/api-client";
import type { Repo } from "../../lib/types";

let repos: Repo[] = [];
let error = "";

try {
  repos = await listRepos();
} catch (e) {
  error = e instanceof Error ? e.message : String(e);
}

// Redirect to first repo if available
if (repos.length > 0) {
  return Astro.redirect(`/issues/${repos[0].repo_id}`);
}
---

<Layout title="Issues">
  <div class="page-header">
    <div>
      <h1>Issues</h1>
      <p class="subtitle">Open GitHub issues from your onboarded repos</p>
    </div>
  </div>

  <div class="divider"></div>

  {error && <p class="error">{error}</p>}

  {repos.length === 0 && !error && (
    <div class="empty">
      <p>No repositories onboarded yet.</p>
      <p>Add a repo on the <a href="/repos">Repositories</a> page first.</p>
    </div>
  )}
</Layout>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  h1 {
    color: var(--heading);
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .subtitle {
    color: #777;
    font-size: 13px;
    margin-top: 4px;
  }

  .divider {
    height: 1px;
    background: var(--border-subtle);
    margin: 20px 0;
  }

  .error {
    color: #e55;
    padding: 12px;
    background: rgba(238, 85, 85, 0.1);
    border-radius: 6px;
    font-size: 13px;
    margin-bottom: 20px;
  }

  .empty {
    text-align: center;
    padding: 60px 20px;
    color: var(--muted);
    font-size: 14px;
  }

  .empty a {
    color: var(--accent);
    text-decoration: underline;
  }
</style>
