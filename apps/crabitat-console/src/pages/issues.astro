---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import ContentHeader from '../components/ContentHeader.astro';
import IssueList from '../components/IssueList.astro';
import type { IssueWithRepo } from '../components/IssueList.astro';
import { fetchRepos, fetchRepoIssues, fetchWorkflows, fetchMissions, fetchColonies } from '../lib/api-client';
import { mockAgents, mockMessages } from '../lib/mock-data';
import type { RepoRecord, MissionRecord, ColonyRecord, WorkflowRecord } from '../lib/types';

let repos: RepoRecord[] = [];
try { repos = await fetchRepos(); } catch {}

let workflows: WorkflowRecord[] = [];
try { workflows = await fetchWorkflows(); } catch {}

let missions: MissionRecord[] = [];
try { missions = await fetchMissions(); } catch {}

let colonies: ColonyRecord[] = [];
try { colonies = await fetchColonies(); } catch {}

// Fetch real issues from GitHub for each registered repo
const allIssues: IssueWithRepo[] = [];
for (const repo of repos) {
  try {
    const repoIssues = await fetchRepoIssues(repo.repo_id);
    for (const issue of repoIssues) {
      allIssues.push({ ...issue, repo_id: repo.repo_id });
    }
  } catch {}
}

---

<Layout title="Issues — Crabitat Console">
  <Sidebar
    activePage="/issues"
    repoCount={repos.length}
    issueCount={allIssues.length}
    missionCount={missions.length}
    agentCount={mockAgents.length}
    messageCount={mockMessages.length}
    workflowCount={workflows.length}
  />

  <div class="content">
    <ContentHeader title="Issues" />
    <div class="section">
      <IssueList issues={allIssues} repos={repos} colonies={colonies} workflows={workflows} />
    </div>
  </div>
</Layout>
