---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import ContentHeader from '../components/ContentHeader.astro';
import { fetchStatus, fetchWorkflows } from '../lib/api-client';
import type { StatusSnapshot, WorkflowRecord } from '../lib/types';

let status: StatusSnapshot | null = null;
try { status = await fetchStatus(); } catch {}

let workflows: WorkflowRecord[] = [];
try { workflows = await fetchWorkflows(); } catch {}

const repos = status?.repos ?? [];
const missions = status?.missions ?? [];
const crabs = status?.crabs ?? [];
---

<Layout title="Messages — Crabitat Console">
  <Sidebar
    activePage="/messages"
    repoCount={repos.length}
    issueCount={status?.summary.cached_issue_count ?? 0}
    missionCount={missions.length}
    agentCount={crabs.length}
    messageCount={0}
    workflowCount={workflows.length}
  />

  <div class="content">
    <ContentHeader title="Messages" />
    <div class="section">
      <div class="data-panel">
        <div class="data-panel-header">
          <span class="data-panel-title">Messages</span>
          <span class="content-count">0</span>
        </div>
        <div class="data-panel-body">
          <div class="empty-state">
            <div class="empty-state-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            </div>
            <div class="empty-state-title">Coming soon</div>
            <p class="empty-state-desc">Agent-to-agent messaging is not yet implemented.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
