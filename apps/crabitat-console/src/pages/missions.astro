---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import MissionPipeline from '../components/MissionPipeline.astro';
import CreateMissionModal from '../components/CreateMissionModal.astro';
import { fetchRepos, fetchWorkflows, fetchMissions, fetchColonies, fetchTasks } from '../lib/api-client';
import { mockIssues, mockAgents, mockMessages } from '../lib/mock-data';
import type { RepoRecord, MissionRecord, ColonyRecord, TaskRecord, WorkflowRecord } from '../lib/types';

let repos: RepoRecord[] = [];
try { repos = await fetchRepos(); } catch {}

let workflows: WorkflowRecord[] = [];
try { workflows = await fetchWorkflows(); } catch {}

let missions: MissionRecord[] = [];
try { missions = await fetchMissions(); } catch {}

let colonies: ColonyRecord[] = [];
try { colonies = await fetchColonies(); } catch {}

let tasks: TaskRecord[] = [];
try { tasks = await fetchTasks(); } catch {}

---

<Layout title="Missions — Crabitat Console">
  <Sidebar
    activePage="/missions"
    repoCount={repos.length}
    issueCount={mockIssues.length}
    missionCount={missions.length}
    agentCount={mockAgents.length}
    messageCount={mockMessages.length}
    workflowCount={workflows.length}
  />

  <div class="content">
    <header class="content-header">
      <div class="content-title-group">
        <h1 class="content-title">Missions</h1>
      </div>
      <div class="header-actions">
        <button class="btn btn--icon" id="missions-add-btn" title="Create mission">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 5v14M5 12h14"/>
          </svg>
        </button>
      </div>
    </header>
    <div class="section">
      <MissionPipeline missions={missions} tasks={tasks} colonies={colonies} />
    </div>
  </div>

  <CreateMissionModal colonies={colonies} workflows={workflows} />
</Layout>

<script>
  const addBtn = document.getElementById('missions-add-btn');
  if (addBtn) {
    addBtn.addEventListener('click', () => {
      (window as any).openCreateMissionModal?.();
    });
  }
</script>
