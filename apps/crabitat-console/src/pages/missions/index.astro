---
import Layout from "../../layouts/Layout.astro";
import { listMissions } from "../../lib/api-client";
import type { Mission } from "../../lib/types";

let missions: Mission[] = [];
let error = "";

try {
  missions = await listMissions();
} catch (e) {
  error = e instanceof Error ? e.message : String(e);
}

const completed = missions.filter(m => m.status === 'completed').length;
const failed = missions.filter(m => m.status === 'failed').length;
const active = missions.filter(m => m.status === 'pending' || m.status === 'running').length;
const total = missions.length;
const successRate = (completed + failed) > 0 
  ? Math.round((completed / (completed + failed)) * 100) 
  : 0;

function timeAgo(dateStr: string): string {
  if (!dateStr) return "";
  const now = Date.now();
  const then = new Date(dateStr).getTime();
  const seconds = Math.floor((now - then) / 1000);
  if (seconds < 60) return "just now";
  const minutes = Math.floor(seconds / 60);
  if (minutes < 60) return `${minutes}m ago`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `${hours}h ago`;
  return `${Math.floor(hours / 24)}d ago`;
}
---

<Layout title="Missions">
  <div class="page-header">
    <div>
      <h1>Missions</h1>
      <p class="subtitle">History of all agentic runs</p>
    </div>
  </div>

  <div class="stats-bar">
    <div class="stat-item">
      <span class="stat-label">Total</span>
      <span class="stat-value">{total}</span>
    </div>
    <div class="stat-item">
      <span class="stat-label">Active</span>
      <span class="stat-value">{active}</span>
    </div>
    <div class="stat-item">
      <span class="stat-label">Completed</span>
      <span class="stat-value text-success">{completed}</span>
    </div>
    <div class="stat-item">
      <span class="stat-label">Failed</span>
      <span class="stat-value text-error">{failed}</span>
    </div>
    <div class="stat-item">
      <span class="stat-label">Success Rate</span>
      <span class="stat-value">{successRate}%</span>
    </div>
  </div>

  <div class="tabs">
    <button class="tab-btn active" data-tab="active">Active ({active})</button>
    <button class="tab-btn" data-tab="completed">Completed ({completed})</button>
    <button class="tab-btn" data-tab="failed">Failed ({failed})</button>
  </div>

  <div class="divider"></div>

  {error && <p class="message error">{error}</p>}

  {missions.length === 0 && !error && (
    <div class="empty-state">
      <div class="icon">🚀</div>
      <h2>No Missions Yet</h2>
      <p>Missions are created when you launch a workflow against an issue.</p>
      <a href="/issues" class="primary-btn">Go to Issues</a>
    </div>
  )}

  <div class="mission-list">
    {missions.map((m) => {
      const displayStatus = (m.status === 'pending' || m.status === 'running') ? 'active' : m.status;
      return (
        <a href={`/missions/${m.mission_id}`} class="mission-row" data-status={displayStatus}>
          <div class="mission-main">
            <div class={`status-dot ${m.status}`}></div>
            <div class="mission-info">
              <span class="workflow-name">{m.workflow_name}</span>
              <span class="issue-ref">{m.repo_id} #{m.issue_number}</span>
            </div>
          </div>
          <div class="mission-meta">
            <span class="time">{timeAgo(m.created_at)}</span>
            <span class="mission-id">ID: {m.mission_id.slice(0, 8)}</span>
            <span class="chevron">→</span>
          </div>
        </a>
      );
    })}
    <div id="tab-empty-state" class="empty-state" style="display: none;">
      <div class="icon">🔍</div>
      <h2>No Missions Found</h2>
      <p>There are no missions with this status.</p>
    </div>
  </div>
</Layout>

<script>
  const tabs = document.querySelectorAll('.tab-btn');
  const missions = document.querySelectorAll('.mission-row');
  const emptyState = document.getElementById('tab-empty-state');

  function filterMissions(status: string) {
    let visibleCount = 0;
    missions.forEach(mission => {
      if (mission instanceof HTMLElement) {
        if (mission.getAttribute('data-status') === status) {
          mission.style.display = 'flex';
          visibleCount++;
        } else {
          mission.style.display = 'none';
        }
      }
    });

    if (emptyState) {
      emptyState.style.display = visibleCount === 0 && missions.length > 0 ? 'block' : 'none';
    }
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const status = tab.getAttribute('data-tab') || 'active';
      filterMissions(status);
    });
  });

  // Initial filter
  const activeTab = document.querySelector('.tab-btn.active');
  if (activeTab) {
    const status = activeTab.getAttribute('data-tab') || 'active';
    filterMissions(status);
  }
</script>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 32px;
  }

  h1 {
    color: var(--heading);
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .subtitle {
    color: var(--muted);
    font-size: 14px;
    margin-top: 4px;
  }

  .stats-bar {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 16px;
    margin-bottom: 32px;
    padding: 20px;
    background: var(--card);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .stat-label {
    color: var(--muted);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }

  .stat-value {
    color: var(--heading);
    font-size: 24px;
    font-weight: 700;
    font-family: monospace;
  }

  .text-success { color: var(--status-success); }
  .text-error { color: var(--status-error); }

  .tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
  }

  .tab-btn {
    padding: 8px 16px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    color: var(--muted);
    border: 1px solid transparent;
    transition: all 0.2s;
    background: transparent;
  }

  .tab-btn:hover {
    color: var(--heading);
    background: var(--btn-bg);
  }

  .tab-btn.active {
    color: var(--heading);
    background: var(--btn-bg);
    border-color: var(--border);
  }

  .divider {
    height: 1px;
    background: var(--border-subtle);
    margin: 16px 0 24px;
  }

  .empty-state {
    text-align: center;
    padding: 80px 40px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    max-width: 600px;
    margin: 40px auto;
  }

  .empty-state .icon { font-size: 48px; margin-bottom: 24px; }
  .empty-state h2 { color: var(--heading); font-size: 24px; margin-bottom: 16px; }
  .empty-state p { color: var(--muted); font-size: 16px; margin-bottom: 32px; }

  .primary-btn {
    display: inline-block;
    background: var(--primary-bg);
    color: var(--primary-text);
    text-decoration: none;
    padding: 12px 32px;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 600;
    transition: all 0.2s;
  }

  .mission-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 1000px;
  }

  .mission-row {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
  }

  .mission-row:hover {
    border-color: var(--row-hover-border);
    background: var(--row-hover-bg);
    transform: translateX(4px);
  }

  .mission-row:hover .workflow-name {
    color: var(--heading);
  }

  .mission-row:hover .issue-ref,
  .mission-row:hover .mission-meta {
    color: var(--row-hover-text);
  }

  .mission-main {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .status-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .status-dot.pending { background: var(--status-warning); box-shadow: 0 0 8px var(--status-warning-bg); }
  .status-dot.running { background: var(--status-info); box-shadow: 0 0 8px var(--status-info-bg); }
  .status-dot.completed { background: var(--status-success); box-shadow: 0 0 8px var(--status-success-bg); }
  .status-dot.failed { background: var(--status-error); box-shadow: 0 0 8px var(--status-error-bg); }

  .mission-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .workflow-name {
    color: var(--heading);
    font-size: 16px;
    font-weight: 600;
  }

  .issue-ref {
    color: var(--muted);
    font-size: 13px;
    font-family: monospace;
  }

  .mission-meta {
    display: flex;
    align-items: center;
    gap: 24px;
    color: var(--muted);
    font-size: 13px;
  }

  .time { font-weight: 500; }
  .mission-id { font-family: monospace; opacity: 0.6; }
  .chevron { font-size: 18px; opacity: 0.4; }

  .message.error {
    background: var(--status-error-bg);
    color: var(--status-error);
    padding: 12px 16px;
    border-radius: 8px;
    margin-bottom: 24px;
  }
</style>
