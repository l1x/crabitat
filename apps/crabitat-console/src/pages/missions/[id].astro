---
import Layout from "../../layouts/Layout.astro";
import { getMission } from "../../lib/api-client";
import type { Mission, Task, StateHistoryEntry } from "../../lib/types";

const { id } = Astro.params;

let mission: Mission | null = null;
let tasks: Task[] = [];
let stateHistory: StateHistoryEntry[] = [];
let error = "";

try {
  const data = await getMission(id!);
  mission = data.mission;
  tasks = data.tasks;
  stateHistory = data.state_history || [];
} catch (e) {
  error = e instanceof Error ? e.message : String(e);
}

function formatDuration(ms: number): string {
  if (ms < 1000) return `${ms}ms`;
  const seconds = Math.floor(ms / 1000);
  if (seconds < 60) return `${seconds}s`;
  const minutes = Math.floor(seconds / 60);
  const remainSec = seconds % 60;
  if (minutes < 60) return `${minutes}m ${remainSec}s`;
  const hours = Math.floor(minutes / 60);
  const remainMin = minutes % 60;
  return `${hours}h ${remainMin}m`;
}

function stateDuration(entry: StateHistoryEntry): string {
  const start = new Date(entry.entered_at).getTime();
  const end = entry.exited_at ? new Date(entry.exited_at).getTime() : Date.now();
  return formatDuration(end - start);
}
---

<Layout title="Mission Detail">
  <div class="page-header">
    <div>
      <div class="breadcrumb">
        <a href="/missions">Missions</a> / <span>{id?.slice(0, 8)}...</span>
      </div>
      <h1>{mission?.workflow_name}</h1>
      <p class="subtitle">
        Mission for <a href={`https://github.com/${mission?.repo_owner}/${mission?.repo_name}/issues/${mission?.issue_number}`} target="_blank" rel="noopener noreferrer">Issue #{mission?.issue_number}</a> in {mission?.repo_owner}/{mission?.repo_name}
      </p>
    </div>
    <div class={`status-badge ${mission?.status}`}>{mission?.status}</div>
  </div>

  <div class="divider"></div>

  {error && <p class="message error">{error}</p>}

  {stateHistory.length > 0 && (
    <div class="state-timeline">
      <h3>State Timeline</h3>
      <div class="timeline-track">
        {stateHistory.map((entry) => (
          <div class={`timeline-entry ${entry.state}`}>
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <span class="timeline-state">{entry.state}</span>
              <span class="timeline-duration">
                {stateDuration(entry)}{!entry.exited_at && ' (active)'}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  <div class="mission-container">
    <div class="pipeline">
      <h3>Task Pipeline</h3>
      <div class="task-list">
        {tasks.map((task, i) => (
          <div class="task-card">
            <div class="task-header">
              <div class="task-step">
                <span class="step-num">{i + 1}</span>
                <span class="step-id">{task.step_id}</span>
              </div>
              <div class={`task-status ${task.status}`}>{task.status}</div>
            </div>

            {task.runs && task.runs.length > 0 && task.runs[0] && (
              <div class="run-stats">
                <div class="stat">
                  <span class="stat-label">Duration</span>
                  <span class="stat-value">
                    {task.runs[0].duration_ms !== null
                      ? (task.runs[0].duration_ms / 1000).toFixed(1) + 's'
                      : '—'}
                  </span>
                </div>
                <div class="stat">
                  <span class="stat-label">Tokens</span>
                  <span class="stat-value">{task.runs[0].tokens_used || '—'}</span>
                </div>
              </div>
            )}

            {task.status === 'failed' && task.runs && task.runs.length > 0 && task.runs[0] && task.runs[0].logs && (
              <div class="run-logs">
                <div class="run-logs-header">Run Logs</div>
                <pre class="run-logs-content">{task.runs[0].logs}</pre>
              </div>
            )}

            <div class="prompt-container">
              <div class="prompt-header">
                <span>Assembled Prompt</span>
                <button class="copy-btn" data-prompt={task.assembled_prompt}>Copy</button>
              </div>
              <div class="markdown-content" data-content={task.assembled_prompt}></div>
            </div>

            {task.status === 'failed' && (
              <div class="retry-section" data-task-id={task.task_id}>
                <details class="context-details">
                  <summary>Add Context</summary>
                  <textarea class="retry-context" placeholder="Optional guidance for the agent..."></textarea>
                </details>
                <div class="retry-actions">
                  <button class="retry-btn">Retry</button>
                  <span class="retry-error" hidden></span>
                </div>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>

<script>
  import { marked } from 'marked';

  // Render markdown content
  document.querySelectorAll('.markdown-content').forEach(el => {
    const content = el.getAttribute('data-content') || '';
    el.innerHTML = marked.parse(content) as string;
  });

  // Simple copy to clipboard logic
  document.addEventListener('click', (e) => {
    const btn = (e.target as Element).closest('.copy-btn');
    if (!btn) return;

    const text = btn.getAttribute('data-prompt') || '';
    navigator.clipboard.writeText(text);

    const originalText = btn.textContent;
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = originalText; }, 2000);
  });

  // Retry failed tasks
  document.addEventListener('click', async (e) => {
    const btn = (e.target as Element).closest('.retry-btn') as HTMLButtonElement | null;
    if (!btn) return;

    const section = btn.closest('.retry-section') as HTMLElement;
    const taskId = section.dataset.taskId;
    const textarea = section.querySelector('.retry-context') as HTMLTextAreaElement | null;
    const errorSpan = section.querySelector('.retry-error') as HTMLElement;
    const context = textarea?.value?.trim() || undefined;

    btn.disabled = true;
    btn.textContent = 'Retrying...';
    errorSpan.hidden = true;

    try {
      const res = await fetch(`http://localhost:3001/v1/tasks/${taskId}/retry`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(context ? { context } : {}),
      });
      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.error || `Failed to retry task: ${res.status}`);
      }
      window.location.reload();
    } catch (err: any) {
      errorSpan.textContent = err.message || 'Retry failed';
      errorSpan.hidden = false;
      btn.disabled = false;
      btn.textContent = 'Retry';
    }
  });
</script>

<style>
  .breadcrumb {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 8px;
  }

  .breadcrumb a:hover {
    color: var(--heading);
  }

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  h1 {
    color: var(--heading);
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .subtitle {
    color: var(--muted);
    font-size: 14px;
    margin-top: 4px;
  }

  .subtitle a {
    color: var(--heading);
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px solid var(--border-subtle);
  }

  .subtitle a:hover {
    border-color: var(--heading);
  }

  .status-badge {
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .status-badge.pending { background: var(--status-warning-bg); color: var(--status-warning); border: 1px solid var(--status-warning-border); }
  .status-badge.running { background: var(--status-info-bg); color: var(--status-info); border: 1px solid var(--status-info-border); }
  .status-badge.completed { background: var(--status-success-bg); color: var(--status-success); border: 1px solid var(--status-success-border); }
  .status-badge.failed { background: var(--status-error-bg); color: var(--status-error); border: 1px solid var(--status-error-border); }

  .divider {
    height: 1px;
    background: var(--border-subtle);
    margin: 24px 0 32px;
  }

  .pipeline h3 {
    font-size: 18px;
    color: var(--heading);
    margin-bottom: 20px;
  }

  .task-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .task-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
  }

  .task-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .task-step {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .step-num {
    width: 24px;
    height: 24px;
    background: var(--btn-border);
    color: var(--heading);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
  }

  .step-id {
    font-size: 16px;
    font-weight: 600;
    color: var(--heading);
  }

  .task-status {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 4px;
    background: var(--overlay-medium);
    color: var(--muted);
  }

  .run-stats {
    display: flex;
    gap: 24px;
    margin-bottom: 16px;
    padding: 0 4px;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--muted);
    letter-spacing: 0.5px;
  }

  .stat-value {
    font-size: 14px;
    font-weight: 600;
    color: var(--heading);
    font-family: monospace;
  }

  .prompt-container {
    background: var(--code-bg);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    overflow: hidden;
  }

  .prompt-header {
    background: var(--overlay-subtle);
    padding: 8px 16px;
    border-bottom: 1px solid var(--border-subtle);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    color: var(--muted);
    font-weight: 600;
  }

  .copy-btn {
    background: transparent;
    border: 1px solid var(--btn-border);
    color: var(--muted);
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 10px;
    cursor: pointer;
  }

  .copy-btn:hover {
    color: var(--heading);
    border-color: var(--muted);
  }

  .markdown-content {
    padding: 24px;
    font-size: 14px;
    color: var(--body);
    line-height: 1.6;
    max-height: 500px;
    overflow-y: auto;
    background: var(--code-bg);
  }

  .markdown-content :global(h1),
  .markdown-content :global(h2),
  .markdown-content :global(h3) {
    color: var(--heading);
    margin-top: 24px;
    margin-bottom: 12px;
    font-weight: 700;
  }

  .markdown-content :global(h1) { font-size: 20px; border-bottom: 1px solid var(--border-subtle); padding-bottom: 8px; }
  .markdown-content :global(h2) { font-size: 18px; }
  .markdown-content :global(h3) { font-size: 16px; }

  .markdown-content :global(p) { margin-bottom: 16px; }

  .markdown-content :global(code) {
    background: var(--overlay-medium);
    padding: 2px 6px;
    border-radius: 4px;
    font-family: monospace;
    font-size: 13px;
  }

  .markdown-content :global(pre) {
    background: var(--code-bg);
    padding: 16px;
    border-radius: 8px;
    margin-bottom: 16px;
    overflow-x: auto;
    border: 1px solid var(--border-subtle);
  }

  .markdown-content :global(pre code) {
    background: transparent;
    padding: 0;
  }

  .markdown-content :global(ul),
  .markdown-content :global(ol) {
    margin-bottom: 16px;
    padding-left: 24px;
  }

  .markdown-content :global(li) { margin-bottom: 4px; }

  .state-timeline {
    margin-bottom: 32px;
  }

  .state-timeline h3 {
    font-size: 18px;
    color: var(--heading);
    margin-bottom: 20px;
  }

  .timeline-track {
    display: flex;
    gap: 0;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px 24px;
    overflow-x: auto;
  }

  .timeline-entry {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px;
    position: relative;
    flex-shrink: 0;
  }

  .timeline-entry:not(:last-child)::after {
    content: '';
    position: absolute;
    right: -1px;
    top: 50%;
    transform: translateY(-50%);
    width: 0;
    height: 0;
    border-top: 6px solid transparent;
    border-bottom: 6px solid transparent;
    border-left: 6px solid var(--border-subtle);
  }

  .timeline-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .timeline-entry.pending .timeline-dot { background: var(--status-warning); }
  .timeline-entry.running .timeline-dot { background: var(--status-info); }
  .timeline-entry.completed .timeline-dot { background: var(--status-success); }
  .timeline-entry.failed .timeline-dot { background: var(--status-error); }

  .timeline-content {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .timeline-state {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--heading);
  }

  .timeline-duration {
    font-size: 12px;
    color: var(--muted);
    font-family: monospace;
  }

  .message.error {
    background: var(--status-error-bg);
    color: var(--status-error);
    padding: 12px 16px;
    border-radius: 8px;
    margin-bottom: 24px;
  }

  .run-logs {
    background: var(--code-bg);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    margin-bottom: 16px;
    overflow: hidden;
  }

  .run-logs-header {
    background: var(--overlay-subtle);
    padding: 8px 16px;
    border-bottom: 1px solid var(--border-subtle);
    font-size: 12px;
    color: var(--muted);
    font-weight: 600;
  }

  .run-logs-content {
    padding: 16px;
    font-size: 13px;
    font-family: monospace;
    color: var(--body);
    line-height: 1.5;
    max-height: 300px;
    overflow-y: auto;
    margin: 0;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .retry-section {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--border-subtle);
  }

  .context-details {
    margin-bottom: 12px;
  }

  .context-details summary {
    font-size: 13px;
    color: var(--muted);
    cursor: pointer;
    font-weight: 600;
  }

  .context-details summary:hover {
    color: var(--heading);
  }

  .retry-context {
    width: 100%;
    min-height: 80px;
    margin-top: 8px;
    padding: 12px;
    background: var(--code-bg);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    color: var(--body);
    font-family: monospace;
    font-size: 13px;
    resize: vertical;
    box-sizing: border-box;
  }

  .retry-context:focus {
    outline: none;
    border-color: var(--status-error);
  }

  .retry-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .retry-btn {
    background: var(--status-error-bg);
    color: var(--status-error);
    border: 1px solid var(--status-error-border);
    padding: 6px 20px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
  }

  .retry-btn:hover:not(:disabled) {
    background: var(--status-error);
    color: var(--card);
  }

  .retry-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .retry-error {
    font-size: 13px;
    color: var(--status-error);
  }
</style>
